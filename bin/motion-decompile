#!/usr/bin/env node
'use strict';

const fs = require('fs');
const os = require('os');
const path = require('path');
const { spawnSync } = require('child_process');

const ROOT = path.resolve(__dirname, '..');
const AB = path.join(ROOT, 'bin', 'capture-browser');
const ENGINE = path.join(ROOT, 'extension', 'capture-animation.js');
const DEFAULT_VIEWPORT = [1280, 800];
const DEFAULT_MAX_OUTPUT = 5_000_000;
const DEFAULT_READY_TIMEOUT_MS = 8_000;
const DEFAULT_READY_STABLE_MS = 700;
const DEFAULT_OPEN_DELAY_MS = 750;

let lastOpenAt = 0;

function usage() {
  console.log(`motion-decompile

Usage:
  bin/motion-decompile scout <url> [--viewport 1280x800] [--slug name] [--runs-dir runs] [--max-hover-captures 10] [--keep-open] [--ready-timeout-ms 8000] [--capture-strategy reuse-page]
  bin/motion-decompile decompile <url> [--viewport 1280x800] [--slug name] [--runs-dir runs] [--max-hover-captures 10] [--keep-open] [--ready-timeout-ms 8000] [--capture-strategy reuse-page]
  bin/motion-decompile decompile <run-dir> [manifest.json] [--keep-open] [--ready-timeout-ms 8000] [--capture-strategy reuse-page]
  bin/motion-decompile init <url> [--viewport 1280x800] [--slug name] [--runs-dir runs] [--no-open]
  bin/motion-decompile map <run-dir>
  bin/motion-decompile plan <run-dir> [--out manifest.proposed.json] [--max-hover-captures 10]
  bin/motion-decompile capture <run-dir> [manifest.json] [--ready-timeout-ms 8000] [--capture-strategy reuse-page]
  bin/motion-decompile assemble <run-dir>
  bin/motion-decompile report <run-dir>
  bin/motion-decompile run <manifest.json> [--slug name] [--runs-dir runs] [--keep-open] [--ready-timeout-ms 8000] [--capture-strategy reuse-page]

Readiness/rate-limit options:
  --ready-timeout-ms N   wait this long for real page content before mapping/capturing
  --ready-stable-ms N    require a stable DOM/text snapshot for this long
  --open-delay-ms N      polite delay between fresh page opens
  --no-ready-wait        skip page-state readiness checks
  --capture-strategy S   reuse-page (default) or fresh
  --fresh-captures       shorthand for --capture-strategy fresh

Capture-repair loop (off by default; inert unless a provider is configured):
  --repair-cmd CMD       external provider: \`CMD <input.json>\` writes output.json,
                         prints its path on stdout (design §5)
  --repair-max-retries N per-capture retries (default 2)
  --repair-budget N      per-run attempt ceiling (default min(2×repairable, 24))
  --repair-confidence-floor F  skip a retry below this provider confidence (default 0.4)
  --repair-causes LIST   comma list of repairable buckets
                         (default occlusion,hidden_not_visible,inert_representative)

Manifest capture examples:
  { "id": "work-card-hover", "type": "hover", "root": "a.work_home_item_link", "waitMs": 1200 }
  { "id": "faq-accordion", "type": "click", "root": "div.g_faq_item.w-dyn-item", "action": "click div.g_faq_item.w-dyn-item", "waitMs": 900 }
  { "id": "hero-load", "type": "boot", "boot": { "selectors": ["h1", "[class*=split]"], "ms": 4000 }, "waitMs": 4300 }
`);
}

function parseFlags(argv) {
  const flags = {};
  const positionals = [];
  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === '--viewport') {
      flags.viewport = parseViewport(argv[++i]);
    } else if (arg === '--slug') {
      flags.slug = argv[++i];
    } else if (arg === '--runs-dir') {
      flags.runsDir = argv[++i];
    } else if (arg === '--out') {
      flags.out = argv[++i];
    } else if (arg === '--max-hover-captures') {
      flags.maxHoverCaptures = Number(argv[++i]);
    } else if (arg === '--ready-timeout-ms') {
      flags.readyTimeoutMs = Number(argv[++i]);
    } else if (arg === '--ready-stable-ms') {
      flags.readyStableMs = Number(argv[++i]);
    } else if (arg === '--open-delay-ms') {
      flags.openDelayMs = Number(argv[++i]);
    } else if (arg === '--no-ready-wait') {
      flags.noReadyWait = true;
    } else if (arg === '--capture-strategy') {
      flags.captureStrategy = argv[++i];
    } else if (arg === '--fresh-captures') {
      flags.captureStrategy = 'fresh';
    } else if (arg === '--repair-cmd') {
      flags.repairCmd = argv[++i];
    } else if (arg === '--repair-max-retries') {
      flags.repairMaxRetries = Number(argv[++i]);
    } else if (arg === '--repair-budget') {
      flags.repairBudget = Number(argv[++i]);
    } else if (arg === '--repair-confidence-floor') {
      flags.repairConfidenceFloor = Number(argv[++i]);
    } else if (arg === '--repair-causes') {
      flags.repairCauses = String(argv[++i] || '').split(',').map(s => s.trim()).filter(Boolean);
    } else if (arg === '--no-open') {
      flags.noOpen = true;
    } else if (arg === '--keep-open') {
      flags.keepOpen = true;
    } else if (arg === '--help' || arg === '-h') {
      flags.help = true;
    } else if (arg.startsWith('--')) {
      throw new Error(`Unknown option: ${arg}`);
    } else {
      positionals.push(arg);
    }
  }
  return { flags, positionals };
}

function parseViewport(value) {
  if (!value) return DEFAULT_VIEWPORT;
  const match = String(value).match(/^(\d+)[x,](\d+)$/);
  if (!match) throw new Error(`Invalid viewport "${value}". Use WIDTHxHEIGHT, for example 1280x800.`);
  return [Number(match[1]), Number(match[2])];
}

function readJson(file) {
  return JSON.parse(fs.readFileSync(file, 'utf8'));
}

function writeJson(file, data) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  fs.writeFileSync(file, `${JSON.stringify(data, null, 2)}\n`);
}

function today() {
  return new Date().toISOString().slice(0, 10);
}

function resolveUrl(src, base) {
  try { return new URL(src, base).href; } catch (e) { return src; }
}

function pctText(ratio) {
  const n = Number(ratio);
  return Number.isFinite(n) ? `${Math.round(n * 100)}%` : 'unknown';
}

function slugify(value) {
  const slug = String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
  return slug || 'run';
}

function runDirFor(url, flags = {}) {
  const parsed = new URL(url);
  const host = parsed.host.toLowerCase().replace(/[^a-z0-9.-]+/g, '-').replace(/^-+|-+$/g, '') || 'site';
  const urlSlug = slugify(flags.slug || parsed.pathname || 'run');
  const base = path.resolve(process.cwd(), flags.runsDir || 'runs', host, `${today()}-${urlSlug}`);
  if (!fs.existsSync(base)) return base;
  for (let i = 2; i < 1000; i += 1) {
    const candidate = `${base}-${i}`;
    if (!fs.existsSync(candidate)) return candidate;
  }
  throw new Error(`Could not find a free run directory near ${base}`);
}

function ensureRunDir(runDir) {
  fs.mkdirSync(path.join(runDir, 'timelines'), { recursive: true });
  const log = path.join(runDir, 'run-log.md');
  if (!fs.existsSync(log)) {
    fs.writeFileSync(log, `# motion-decompile run log\n\nStarted: ${new Date().toISOString()}\n\n`);
  }
}

function appendLog(runDir, line) {
  if (!runDir) return;
  ensureRunDir(runDir);
  fs.appendFileSync(path.join(runDir, 'run-log.md'), `${line}\n`);
}

function quote(value) {
  const text = String(value);
  if (/^[A-Za-z0-9_./:@=+-]+$/.test(text)) return text;
  return `'${text.replace(/'/g, `'\\''`)}'`;
}

function formatCommand(args) {
  const formatted = args.map((arg, index) => {
    if (index === 1 && args[0] === 'eval' && String(arg).length > 160) {
      return quote(`${String(arg).slice(0, 157)}...`);
    }
    return quote(arg);
  });
  return `./bin/capture-browser ${formatted.join(' ')}`;
}

function runBrowser(args, options = {}) {
  appendLog(options.runDir, `- ${new Date().toISOString()} \`${formatCommand(args)}\``);
  const result = spawnSync(AB, args, {
    cwd: ROOT,
    encoding: 'utf8',
    maxBuffer: options.maxBuffer || DEFAULT_MAX_OUTPUT + 200_000,
  });
  if (result.status !== 0) {
    const detail = [result.stderr, result.stdout].filter(Boolean).join('\n').trim();
    throw new Error(`Browser command failed: ${formatCommand(args)}${detail ? `\n${detail}` : ''}`);
  }
  return result.stdout.trim();
}

function sleepMs(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
}

function parseJsonOutput(stdout) {
  const text = stdout.trim();
  if (!text) return null;
  let value = JSON.parse(text);
  if (typeof value === 'string') {
    const inner = value.trim();
    if ((inner.startsWith('{') && inner.endsWith('}')) || (inner.startsWith('[') && inner.endsWith(']'))) {
      value = JSON.parse(inner);
    }
  }
  return value;
}

function evalJson(js, runDir, maxOutput = DEFAULT_MAX_OUTPUT) {
  return parseJsonOutput(runBrowser(['eval', js, '--max-output', String(maxOutput)], {
    runDir,
    maxBuffer: maxOutput + 200_000,
  }));
}

function evalStatement(js, runDir) {
  const body = String(js).trim().replace(/;+$/, '');
  evalJson(`(() => { ${body}; return { ok: true }; })()`, runDir, 200_000);
}

class PageBlockedError extends Error {
  constructor(message, state) {
    super(message);
    this.name = 'PageBlockedError';
    this.fatalPageState = true;
    this.state = state;
  }
}

function finiteNumber(value, fallback) {
  return Number.isFinite(Number(value)) ? Number(value) : fallback;
}

function optionNumber(...values) {
  for (const value of values) {
    if (value !== undefined && value !== null && value !== '') return Number(value);
  }
  return undefined;
}

function readyOptions(manifest = {}, flags = {}, capture = {}) {
  return {
    skip: Boolean(flags.noReadyWait || manifest.waitForReady === false || capture.waitForReady === false),
    timeoutMs: finiteNumber(
      optionNumber(capture.readyTimeoutMs, manifest.readyTimeoutMs, flags.readyTimeoutMs),
      DEFAULT_READY_TIMEOUT_MS
    ),
    stableMs: finiteNumber(
      optionNumber(capture.readyStableMs, manifest.readyStableMs, flags.readyStableMs),
      DEFAULT_READY_STABLE_MS
    ),
  };
}

function openDelayMs(manifest = {}, flags = {}, capture = {}) {
  return Math.max(0, finiteNumber(
    optionNumber(capture.openDelayMs, manifest.openDelayMs, flags.openDelayMs),
    DEFAULT_OPEN_DELAY_MS
  ));
}

function pageStateProbe() {
  return `(() => {
    const textOf = el => (el && (el.innerText || el.textContent) || '').replace(/\\s+/g, ' ').trim();
    const short = value => String(value || '').replace(/\\s+/g, ' ').trim().slice(0, 180);
    const cssPath = el => {
      if (!el || el.nodeType !== 1) return '';
      if (el.id) return '#' + CSS.escape(el.id);
      const tag = el.tagName.toLowerCase();
      const classes = Array.from(el.classList || []).slice(0, 3).map(cls => '.' + CSS.escape(cls)).join('');
      return tag + classes;
    };
    const visible = el => {
      if (!el || el.nodeType !== 1) return false;
      const cs = getComputedStyle(el);
      if (cs.display === 'none' || cs.visibility === 'hidden' || Number(cs.opacity || 1) === 0) return false;
      const r = el.getBoundingClientRect();
      return r.width > 2 && r.height > 2;
    };
    const bodyText = textOf(document.body);
    const haystack = (document.title + '\\n' + bodyText).toLowerCase();
    const blockers = [];
    const addTextBlocker = (type, pattern) => {
      const match = haystack.match(pattern);
      if (match) blockers.push({ type, evidence: short(match[0]) });
    };
    addTextBlocker('rate-limit', /\\b429\\b|too many requests|rate limit(?:ed)?|try again later|request limit|temporarily unavailable/);
    addTextBlocker('challenge', /just a moment|checking (?:your|if the) (?:browser|site)|verify you are human|captcha|hcaptcha|recaptcha|cloudflare ray|attention required|access denied/);

    const loaderSelector = [
      '[aria-busy="true"]',
      '[role="progressbar"]',
      '.loader',
      '.loading',
      '.preloader',
      '[class*="loader"]',
      '[class*="loading"]',
      '[class*="preloader"]',
      '[class*="page-transition"]',
      '[class*="splash"]',
      '[id*="loader"]',
      '[id*="loading"]',
      '[id*="preloader"]'
    ].join(',');
    for (const el of Array.from(document.querySelectorAll(loaderSelector)).slice(0, 20)) {
      if (!visible(el)) continue;
      const r = el.getBoundingClientRect();
      const areaRatio = Math.min(1, (r.width * r.height) / Math.max(1, innerWidth * innerHeight));
      const descriptor = short([cssPath(el), el.id, el.className, textOf(el)].join(' '));
      if (areaRatio > 0.25 || /load|preload|progress|splash|transition/i.test(descriptor)) {
        blockers.push({ type: 'loading', evidence: descriptor || cssPath(el), areaRatio: Math.round(areaRatio * 100) / 100 });
        break;
      }
    }

    const waitingShell = bodyText.length < 80 && /loading|please wait|one moment|initializing/i.test(bodyText);
    if (waitingShell) blockers.push({ type: 'loading', evidence: short(bodyText) });

    const blockerTypes = [...new Set(blockers.map(item => item.type))];
    const blocked = blockerTypes.some(type => type === 'rate-limit' || type === 'challenge');
    const loading = blockerTypes.includes('loading') || (document.readyState === 'loading');
    const state = {
      url: location.href,
      title: document.title || '',
      readyState: document.readyState,
      textLength: bodyText.length,
      textSample: short(bodyText),
      elementCount: document.getElementsByTagName('*').length,
      linkCount: document.links.length,
      buttonCount: document.querySelectorAll('button,[role="button"]').length,
      scrollHeight: document.documentElement.scrollHeight,
      viewport: [innerWidth, innerHeight],
      blockers,
      blocked,
      loading,
      stabilityKey: [document.readyState, bodyText.length, document.getElementsByTagName('*').length, document.documentElement.scrollHeight, blockerTypes.join(',')].join('|'),
    };
    state.ready = !blocked && !loading && document.readyState !== 'loading';
    return state;
  })()`;
}

function recordPageState(runDir, record) {
  const file = path.join(runDir, 'page-state.json');
  const existing = optionalJson(file, { records: [] });
  existing.updatedAt = new Date().toISOString();
  existing.records = Array.isArray(existing.records) ? existing.records : [];
  existing.records.push(plainStrings(record));
  writeJson(file, existing);
}

function pageBlockerSummary(state) {
  const blockers = state?.blockers || [];
  if (!blockers.length) return 'unknown page blocker';
  return blockers.map(item => `${item.type}${item.evidence ? ` (${item.evidence})` : ''}`).join(', ');
}

function waitForPageReady(runDir, phase, manifest = {}, flags = {}, capture = {}) {
  const opts = readyOptions(manifest, flags, capture);
  if (opts.skip) {
    appendLog(runDir, `\nPage readiness skipped for ${phase}.\n`);
    return null;
  }

  const started = Date.now();
  let lastKey = null;
  let stableSince = 0;
  let latest = null;
  let outcome = 'timeout';
  const samples = [];

  while (Date.now() - started <= opts.timeoutMs) {
    latest = evalJson(pageStateProbe(), runDir, 700_000);
    samples.push(latest);
    if (latest?.blocked) {
      outcome = 'blocked';
      recordPageState(runDir, {
        phase,
        outcome,
        waitedMs: Date.now() - started,
        state: latest,
        sampledAt: new Date().toISOString(),
      });
      throw new PageBlockedError(`Page appears blocked before ${phase}: ${pageBlockerSummary(latest)}`, latest);
    }

    if (latest?.ready) {
      if (latest.stabilityKey === lastKey) {
        if (!stableSince) stableSince = Date.now();
      } else {
        lastKey = latest.stabilityKey;
        stableSince = Date.now();
      }
      if (Date.now() - stableSince >= opts.stableMs) {
        outcome = 'ready';
        break;
      }
    } else {
      lastKey = latest?.stabilityKey || null;
      stableSince = 0;
    }
    sleepMs(250);
  }

  if (outcome !== 'ready' && latest?.loading) outcome = 'timeout-loading';
  recordPageState(runDir, {
    phase,
    outcome,
    waitedMs: Date.now() - started,
    state: latest,
    sampleCount: samples.length,
    sampledAt: new Date().toISOString(),
  });
  appendLog(runDir, `\nPage readiness ${phase}: ${outcome}${latest ? ` (${latest.readyState}, text ${latest.textLength}, elements ${latest.elementCount})` : ''}.\n`);
  return latest;
}

function selectorPreflight(selector) {
  return `(() => {
    const selector = ${JSON.stringify(selector)};
    const cssPath = el => {
      if (!el || el.nodeType !== 1) return '';
      if (el.id) return '#' + CSS.escape(el.id);
      const tag = el.tagName.toLowerCase();
      const classes = Array.from(el.classList || []).slice(0, 3).map(cls => '.' + CSS.escape(cls)).join('');
      return tag + classes;
    };
    const visible = el => {
      const cs = getComputedStyle(el);
      const r = el.getBoundingClientRect();
      return cs.display !== 'none' && cs.visibility !== 'hidden' && Number(cs.opacity || 1) > 0 && r.width > 1 && r.height > 1;
    };
    const matches = Array.from(document.querySelectorAll(selector));
    const candidates = matches.map((el, index) => {
      const r = el.getBoundingClientRect();
      return {
        index,
        selector: cssPath(el),
        visible: visible(el),
        rect: { x: Math.round(r.x), y: Math.round(r.y), width: Math.round(r.width), height: Math.round(r.height) },
      };
    });
    const chosen = matches.find(visible);
    if (!matches.length) return { selector, status: 'not-found', matchCount: 0, visibleMatchCount: 0, message: 'selector matched no elements' };
    if (!chosen) return { selector, status: 'not-visible', matchCount: matches.length, visibleMatchCount: 0, candidates, message: 'selector matched no visible elements' };
    const rect = chosen.getBoundingClientRect();
    const x = Math.max(1, Math.min(innerWidth - 1, rect.left + rect.width / 2));
    const y = Math.max(1, Math.min(innerHeight - 1, rect.top + rect.height / 2));
    const top = document.elementFromPoint(x, y);
    const hittable = Boolean(top && (top === chosen || chosen.contains(top)));
    const topPath = cssPath(top);
    return {
      selector,
      status: hittable ? 'ok' : 'covered',
      matchCount: matches.length,
      visibleMatchCount: candidates.filter(item => item.visible).length,
      chosen: cssPath(chosen),
      point: { x: Math.round(x), y: Math.round(y) },
      rect: { x: Math.round(rect.x), y: Math.round(rect.y), width: Math.round(rect.width), height: Math.round(rect.height) },
      coveredBy: hittable ? null : topPath,
      message: hittable ? 'selector appears hittable' : 'selector center is covered by ' + (topPath || 'another element'),
    };
  })()`;
}

function selectorPresence(selector) {
  return `(() => {
    const selector = ${JSON.stringify(selector)};
    const matches = Array.from(document.querySelectorAll(selector));
    const visibleCount = matches.filter(el => {
      const cs = getComputedStyle(el);
      const r = el.getBoundingClientRect();
      return cs.display !== 'none' && cs.visibility !== 'hidden' && Number(cs.opacity || 1) > 0 && r.width > 1 && r.height > 1;
    }).length;
    return {
      selector,
      status: matches.length ? (visibleCount ? 'ok' : 'not-visible') : 'not-found',
      matchCount: matches.length,
      visibleMatchCount: visibleCount,
      message: matches.length ? (visibleCount ? 'selector is present' : 'selector matched no visible elements') : 'selector matched no elements',
    };
  })()`;
}

function preflightPresence(runDir, selector, label = 'selector', capture = {}) {
  if (!selector || capture.preflight === false) return null;
  const result = evalJson(selectorPresence(selector), runDir, 300_000);
  if (result.status !== 'ok') {
    throw new Error(`Preflight failed for ${label} ${selector}: ${result.message}`);
  }
  return result;
}

function preflightAction(runDir, action, capture = {}) {
  if (capture.preflight === false) return null;
  if (!action || Array.isArray(action) || typeof action === 'object') return null;
  const { command, rest } = splitAction(action);
  if (!rest) return null;
  if (command === 'scrollintoview') return preflightPresence(runDir, rest, command, capture);
  if (!['click', 'dblclick', 'hover'].includes(command)) return null;
  const result = evalJson(selectorPreflight(rest), runDir, 500_000);
  if (result.status !== 'ok') {
    throw new Error(`Preflight failed for ${command} ${rest}: ${result.message}`);
  }
  return result;
}

// Fixed failure-cause vocabulary. The `cause` field on a failed capture is the
// machine-readable truth (the reason string stays for humans). Shared with
// bin/calib-metrics, which validates against the same list.
const FAILURE_CAUSES = [
  'occlusion', 'hidden_not_visible', 'inert_representative', 'pseudo_element',
  'wrong_trigger_boot_vs_scroll', 'wrong_document_iframe', 'vendor_animation', 'other',
];

// Cheap live probe on a failed element: is it there/visible/occluded, does it
// (or its ::before/::after) carry hover/transition rules on an animatable
// property, and — for boot reveals — are the reveal hosts below the fold? Pure
// reading; never mutates the page. Returns a flat object of signals.
function failureProbe(selector, bootSelectors) {
  return `(() => {
    const selector = ${JSON.stringify(selector || null)};
    const bootSelectors = ${JSON.stringify(Array.isArray(bootSelectors) ? bootSelectors : [])};
    const ANIM = /transform|opacity|filter|clip-path|clip|width|height|color|background|left|right|top|bottom|inset|translate|scale|rotate|margin|padding|\\ball\\b/;
    const esc = v => (window.CSS && CSS.escape) ? CSS.escape(String(v)) : String(v);
    const cssPath = el => {
      if (!el || el.nodeType !== 1) return '';
      if (el.id) return '#' + esc(el.id);
      const tag = el.tagName.toLowerCase();
      const cls = Array.from(el.classList || []).slice(0, 3).map(c => '.' + esc(c)).join('');
      return tag + cls;
    };
    const visibleOf = el => {
      const cs = getComputedStyle(el);
      const r = el.getBoundingClientRect();
      return cs.display !== 'none' && cs.visibility !== 'hidden' && Number(cs.opacity || 1) > 0 && r.width > 1 && r.height > 1;
    };
    const out = {
      selector,
      found: false, visible: false, zeroBox: false, occludedBy: null,
      hoverSelfAnimatable: false, hoverPseudoAnimatable: false, pseudoHasTransition: false,
      bootHosts: { total: 0, below: 0 },
    };

    for (const sel of bootSelectors) {
      let els = [];
      try { els = Array.from(document.querySelectorAll(sel)); } catch (e) { continue; }
      for (const el of els) {
        const r = el.getBoundingClientRect();
        if (r.width < 1 && r.height < 1) continue;
        out.bootHosts.total++;
        if (r.top >= innerHeight) out.bootHosts.below++;
      }
    }

    if (!selector) return out;
    let matches = [];
    try { matches = Array.from(document.querySelectorAll(selector)); } catch (e) { return out; }
    out.found = matches.length > 0;
    const el = matches.find(visibleOf) || matches[0];
    if (!el) return out;
    out.visible = visibleOf(el);
    const r = el.getBoundingClientRect();
    out.zeroBox = r.width <= 1 || r.height <= 1;

    if (out.visible) {
      const x = Math.max(1, Math.min(innerWidth - 1, r.left + r.width / 2));
      const y = Math.max(1, Math.min(innerHeight - 1, r.top + r.height / 2));
      const top = document.elementFromPoint(x, y);
      if (top && top !== el && !el.contains(top) && !top.contains(el)) out.occludedBy = cssPath(top);
    }

    for (const pseudo of ['::before', '::after']) {
      let cs;
      try { cs = getComputedStyle(el, pseudo); } catch (e) { continue; }
      if (!cs) continue;
      const content = cs.content;
      const dur = parseFloat(cs.transitionDuration) || 0;
      if (content && content !== 'none' && content !== 'normal' && dur > 0 && ANIM.test(cs.transitionProperty || '')) {
        out.pseudoHasTransition = true;
      }
    }

    const selfOrAncestor = base => base.split(',').map(s => s.trim()).filter(Boolean).some(b => {
      try { return el.matches(b) || !!el.closest(b); } catch (e) { return false; }
    });
    for (const sheet of Array.from(document.styleSheets)) {
      let rules;
      try { rules = sheet.cssRules; } catch (e) { continue; } // cross-origin sheet, unreadable
      if (!rules) continue;
      for (const rule of Array.from(rules)) {
        const sel = rule.selectorText;
        if (!sel || sel.indexOf(':hover') === -1) continue;
        const decl = rule.style;
        if (!decl) continue;
        if (!(decl.transition || decl.transitionProperty || ANIM.test(decl.cssText || ''))) continue;
        const isPseudo = /::?(before|after)\\b/.test(sel);
        const base = sel.replace(/::?(before|after)\\b/g, '').replace(/:hover/g, '');
        if (!selfOrAncestor(base)) continue;
        if (isPseudo) out.hoverPseudoAnimatable = true; else out.hoverSelfAnimatable = true;
      }
    }
    return out;
  })()`;
}

function runFailureProbe(runDir, selector, bootSelectors) {
  try {
    return evalJson(failureProbe(selector, bootSelectors), runDir, 600_000);
  } catch (error) {
    appendLog(runDir, `\nFailure probe error: ${error.message || error}\n`);
    return null;
  }
}

function preflightCovered(preflight) {
  if (!preflight) return false;
  const arr = Array.isArray(preflight) ? preflight : [preflight];
  return arr.some(p => p && (p.status === 'covered' || p.coveredBy || /covered|occlud/i.test(p.message || '')));
}

// Assign one fixed-vocabulary cause to a failed capture, preferring live probe
// signals and falling back to the reason string when the probe is unavailable.
// Order matters: most-specific structural causes first.
function classifyFailure({ result, type, probe, map, isBoot, scrollTriggerPresent }) {
  const reason = String(result.error || result.summary || '').toLowerCase();
  const dom = map && map.dominantIframe;

  // Dominant cross-origin (or unreadable) iframe: every selector resolves into
  // shell chrome, so any miss here is really the wrong document.
  if (dom && dom.present !== false && dom.src && !(dom.sameOrigin && dom.accessible)) {
    return 'wrong_document_iframe';
  }

  // Occlusion: the target's click point is covered.
  if (preflightCovered(result.preflight)) return 'occlusion';
  if (/covered by|center is covered|is covered|occlud/.test(reason)) return 'occlusion';
  if (probe && probe.occludedBy) return 'occlusion';

  // Boot reveals carry no single root, so the probe only yields bootHosts — the
  // selector-based found/visible checks below don't apply. Classify from the
  // hosts: ScrollTrigger present + hosts below the fold means the motion is
  // scroll-gated, not boot-gated (Part 4 is the recipe fix).
  if (isBoot) {
    if (scrollTriggerPresent && probe && probe.bootHosts && probe.bootHosts.below > 0) {
      return 'wrong_trigger_boot_vs_scroll';
    }
    if (probe && probe.bootHosts && probe.bootHosts.total === 0) return 'hidden_not_visible';
    return 'inert_representative';
  }

  // Absent / zero-box / not visible (and no iframe in play).
  if (probe && (probe.found === false || probe.visible === false || probe.zeroBox === true)) {
    return 'hidden_not_visible';
  }
  if (!probe && /no visible elements|matched no|not found|0x0|zero size|not visible|display:\s*none|hidden/.test(reason)) {
    return 'hidden_not_visible';
  }

  // Hover moved no element layers but the element or its ::before/::after has a
  // hover/transition rule on an animatable property — the motion is in a pseudo
  // element the per-element sampler can't read (suspected; Part 2 is the fix).
  if (probe && (probe.pseudoHasTransition || probe.hoverPseudoAnimatable)) {
    return 'pseudo_element';
  }

  // Hittable but produced no motion and no pseudo styling: genuinely inert.
  if (result.status === 'empty') return 'inert_representative';
  if (probe && probe.found && probe.visible) return 'inert_representative';

  return 'other';
}

function validCause(cause) {
  return FAILURE_CAUSES.includes(cause) ? cause : 'other';
}

// ───────────────────────────────────────────────────────────────────────────
// Capture-repair loop (Part 6 — design: docs/PART-5-repair-loop-design.md)
//
// The LLM decides WHAT/HOW/REPAIR; it NEVER measures motion. These structures
// carry only selectors, action sequences, and a terminal verdict — there is no
// field for a duration/easing/from-to, so a number cannot flow from the
// provider into the spec. Whether a repair worked is decided ONLY by re-running
// the same settle->arm->trigger->wait->dump recipe and reading the engine's
// status/elementsMoved against the machine-checked successCriterion.
// ───────────────────────────────────────────────────────────────────────────

// Closed action enum (design §3). The provider may emit nothing outside this.
const REPAIR_ACTION_KINDS = [
  'retarget_selector', 'use_other_instance', 'scroll_into_view',
  'precondition_action', 'retarget_iframe', 'terminal_give_up',
];
// Terminal verdict causes (design §3).
const TERMINAL_CAUSES = [
  'genuinely_inert', 'genuinely_absent', 'cross_origin_iframe',
  'needs_human', 'provider_error',
];
// rootCause vocabulary = the Part 1 buckets, or "ambiguous" (design §3).
const REPAIR_ROOT_CAUSES = FAILURE_CAUSES.concat(['ambiguous']);
// Which classifier buckets enter the loop by default (design §5, PM ruling §11).
// Narrow on purpose: Parts 2/4 already fixed pseudo_element + wrong_trigger;
// Part 1 handles wrong_document_iframe at the dominant level.
const DEFAULT_REPAIRABLE_CAUSES = ['occlusion', 'hidden_not_visible', 'inert_representative'];
// Repair kinds that mutate page state. M1 (design §11): these MUST re-run on a
// fresh page so they start from REST and cannot leak into later reuse-page
// captures. `fresh:true` on the cloned capture forces the isolated re-open.
const STATEFUL_REPAIR_KINDS = ['precondition_action', 'scroll_into_view', 'retarget_iframe'];
const REPAIR_DEFAULTS = { maxRetries: 2, confidenceFloor: 0.4, budgetMultiplier: 2, budgetCeiling: 24 };

function isStatefulRepairKind(kind) {
  return STATEFUL_REPAIR_KINDS.includes(kind);
}

// Resolve the effective repair config from manifest + CLI flags. Returns null
// when no provider command is configured — the loop is then INERT and the
// current soft-fail behavior is byte-identical (design §1, §5).
function repairConfig(manifest = {}, flags = {}) {
  const block = (manifest && typeof manifest.repair === 'object' && manifest.repair) || {};
  const command = flags.repairCmd || block.command || null;
  if (!command) return null;
  const causes = flags.repairCauses || block.repairableCauses || DEFAULT_REPAIRABLE_CAUSES;
  return {
    command,
    maxRetries: finiteNumber(optionNumber(flags.repairMaxRetries, block.maxRetries), REPAIR_DEFAULTS.maxRetries),
    confidenceFloor: finiteNumber(optionNumber(flags.repairConfidenceFloor, block.confidenceFloor), REPAIR_DEFAULTS.confidenceFloor),
    budget: optionNumber(flags.repairBudget, block.budget) === undefined
      ? null
      : finiteNumber(optionNumber(flags.repairBudget, block.budget), null),
    repairableCauses: Array.isArray(causes) ? causes.filter(c => REPAIR_ROOT_CAUSES.includes(c)) : DEFAULT_REPAIRABLE_CAUSES,
  };
}

// Read-only structural probe of the failed target's neighborhood (design §2).
// Same cost class as failureProbe: one evalJson, never mutates the page. Surfaces
// the three things every repair shape keys on — other instances (each with its
// own occluder), candidate triggers (for precondition repairs, aria-* first),
// and whether anything here is animatable at all (the gate for an honest
// terminal verdict, design §6/§7).
function repairContextProbe(selector) {
  return `(() => {
    const selector = ${JSON.stringify(selector || null)};
    const ANIM = /transform|opacity|filter|clip-path|clip|width|height|color|background|left|right|top|bottom|inset|translate|scale|rotate|margin|padding|\\ball\\b/;
    const esc = v => (window.CSS && CSS.escape) ? CSS.escape(String(v)) : String(v);
    const cssPath = el => {
      if (!el || el.nodeType !== 1) return '';
      if (el.id) return '#' + esc(el.id);
      const tag = el.tagName.toLowerCase();
      const cls = Array.from(el.classList || []).slice(0, 3).map(c => '.' + esc(c)).join('');
      return tag + cls;
    };
    const round = n => Math.round(n);
    const rectOf = el => { const r = el.getBoundingClientRect(); return [round(r.left), round(r.top), round(r.width), round(r.height)]; };
    const visibleOf = el => {
      const cs = getComputedStyle(el);
      const r = el.getBoundingClientRect();
      return cs.display !== 'none' && cs.visibility !== 'hidden' && Number(cs.opacity || 1) > 0 && r.width > 1 && r.height > 1;
    };
    const occluderOf = el => {
      if (!visibleOf(el)) return null;
      const r = el.getBoundingClientRect();
      const x = Math.max(1, Math.min(innerWidth - 1, r.left + r.width / 2));
      const y = Math.max(1, Math.min(innerHeight - 1, r.top + r.height / 2));
      const top = document.elementFromPoint(x, y);
      if (top && top !== el && !el.contains(top) && !top.contains(el)) return cssPath(top);
      return null;
    };
    const matchOf = (el, nth) => ({ nth, visible: visibleOf(el), rect: rectOf(el), display: getComputedStyle(el).display, occludedBy: occluderOf(el) });

    const out = {
      matches: [], ancestors: [], siblings: [], candidateTriggers: [],
      animatableHere: { selfHover: false, pseudoHover: false, childAnimated: false, scrollTriggerBound: false },
    };

    let matches = [];
    if (selector) { try { matches = Array.from(document.querySelectorAll(selector)); } catch (e) { matches = []; } }
    matches.slice(0, 12).forEach((el, nth) => out.matches.push(matchOf(el, nth)));
    const primary = matches.find(visibleOf) || matches[0] || null;

    if (primary) {
      let p = primary.parentElement, depth = 0;
      while (p && depth < 6) {
        const cs = getComputedStyle(p);
        out.ancestors.push({
          tag: p.tagName.toLowerCase(),
          classes: Array.from(p.classList || []).slice(0, 4),
          role: p.getAttribute('role'),
          cursorPointer: cs.cursor === 'pointer',
          ariaHidden: p.getAttribute('aria-hidden'),
          ariaControls: p.getAttribute('aria-controls'),
          ariaExpanded: p.getAttribute('aria-expanded'),
        });
        p = p.parentElement; depth++;
      }
      if (primary.parentElement) {
        Array.from(primary.parentElement.children).filter(c => c !== primary).slice(0, 8)
          .forEach(c => out.siblings.push(Object.assign({ selector: cssPath(c) }, matchOf(c, -1))));
      }
    }

    // Candidate triggers: aria-controls/haspopup/expanded are the highest-signal
    // opener hints, then proximity over a bounded affordance net (no full-DOM
    // cursor scan). opensTarget flags when the aria-controls id maps to the
    // target/its ancestor — the strongest precondition-opener evidence.
    const anchor = (() => {
      if (primary) { const r = primary.getBoundingClientRect(); if (r.width || r.height) return r; }
      for (const a of out.ancestors) { if (a.rect && (a.rect[2] || a.rect[3])) return { left: a.rect[0], top: a.rect[1], width: a.rect[2], height: a.rect[3] }; }
      return { left: innerWidth / 2, top: innerHeight / 2, width: 0, height: 0 };
    })();
    const cx = anchor.left + anchor.width / 2, cy = anchor.top + anchor.height / 2;
    const controlsTarget = el => {
      const ids = (el.getAttribute('aria-controls') || '').split(/\\s+/).filter(Boolean);
      for (const id of ids) {
        const t = document.getElementById(id);
        if (t && (t === primary || (primary && (t.contains(primary) || primary.contains(t))))) return true;
      }
      return false;
    };
    const seen = new Set();
    const pushTrigger = (el, opensTarget, priority) => {
      if (!el || el.nodeType !== 1 || !visibleOf(el)) return;
      const sel = cssPath(el);
      if (!sel || seen.has(sel)) return;
      seen.add(sel);
      const r = el.getBoundingClientRect();
      out.candidateTriggers.push({
        selector: sel,
        text: ((el.innerText || el.textContent || el.getAttribute('aria-label') || '').replace(/\\s+/g, ' ').trim()).slice(0, 60),
        rect: [round(r.left), round(r.top), round(r.width), round(r.height)],
        opensTarget,
        _d: Math.hypot(r.left + r.width / 2 - cx, r.top + r.height / 2 - cy),
        _p: priority,
      });
    };
    let ariaEls = [];
    try { ariaEls = Array.from(document.querySelectorAll('[aria-controls],[aria-haspopup],[aria-expanded]')); } catch (e) {}
    ariaEls.forEach(el => pushTrigger(el, controlsTarget(el) ? 'aria-controls-match' : 'aria', 0));
    let affordances = [];
    try {
      affordances = Array.from(document.querySelectorAll(
        'a[href],button,[role=button],[onclick],[class*=btn],[class*=button],[class*=arrow],[class*=next],[class*=prev],[class*=toggle],[class*=trigger],[class*=open]'
      ));
    } catch (e) {}
    affordances.forEach(el => {
      if (seen.has(cssPath(el))) return;
      const cs = getComputedStyle(el);
      const r = el.getBoundingClientRect();
      const near = Math.hypot(r.left + r.width / 2 - cx, r.top + r.height / 2 - cy) < Math.max(innerWidth, innerHeight);
      if (near || cs.cursor === 'pointer') pushTrigger(el, 'proximity', 1);
    });
    out.candidateTriggers.sort((a, b) => (a._p - b._p) || (a._d - b._d));
    out.candidateTriggers = out.candidateTriggers.slice(0, 12).map(t => { delete t._d; delete t._p; return t; });

    if (primary) {
      for (const pseudo of ['::before', '::after']) {
        let cs; try { cs = getComputedStyle(primary, pseudo); } catch (e) { continue; }
        if (cs && cs.content && cs.content !== 'none' && cs.content !== 'normal' && (parseFloat(cs.transitionDuration) || 0) > 0 && ANIM.test(cs.transitionProperty || '')) {
          out.animatableHere.pseudoHover = true;
        }
      }
      const descendants = Array.from(primary.querySelectorAll('*')).slice(0, 200);
      for (const d of descendants) {
        const cs = getComputedStyle(d);
        if (((parseFloat(cs.transitionDuration) || 0) > 0 && ANIM.test(cs.transitionProperty || '')) || (cs.animationName && cs.animationName !== 'none')) {
          out.animatableHere.childAnimated = true; break;
        }
      }
      const selfOrAncestor = base => base.split(',').map(s => s.trim()).filter(Boolean).some(b => {
        try { return primary.matches(b) || !!primary.closest(b); } catch (e) { return false; }
      });
      for (const sheet of Array.from(document.styleSheets)) {
        let rules; try { rules = sheet.cssRules; } catch (e) { continue; }
        if (!rules) continue;
        for (const rule of Array.from(rules)) {
          const sel = rule.selectorText;
          if (!sel || sel.indexOf(':hover') === -1) continue;
          const decl = rule.style; if (!decl) continue;
          if (!(decl.transition || decl.transitionProperty || ANIM.test(decl.cssText || ''))) continue;
          const base = sel.replace(/::?(before|after)\\b/g, '').replace(/:hover/g, '');
          if (!selfOrAncestor(base)) continue;
          if (/::?(before|after)\\b/.test(sel)) out.animatableHere.pseudoHover = true; else out.animatableHere.selfHover = true;
        }
      }
      try {
        const ST = window.ScrollTrigger || (window.gsap && window.gsap.core && window.gsap.core.globals && window.gsap.core.globals().ScrollTrigger);
        if (ST && typeof ST.getAll === 'function') {
          out.animatableHere.scrollTriggerBound = ST.getAll().some(st => {
            const t = st && (st.trigger || (st.vars && st.vars.trigger));
            return t && t.nodeType === 1 && (t === primary || t.contains(primary) || primary.contains(t));
          });
        }
      } catch (e) {}
    }
    return out;
  })()`;
}

function runRepairContext(runDir, selector) {
  try {
    return evalJson(repairContextProbe(selector), runDir, 600_000);
  } catch (error) {
    appendLog(runDir, `\nRepair-context probe error: ${error.message || error}\n`);
    return null;
  }
}

// Viewport screenshot of the failed state (design §2/§11: viewport scope, with
// the failed element scrolled into view first when it has a box). Returns the
// run-relative path on success, null on failure (never throws into the loop).
function captureRepairScreenshot(runDir, selector, relPath) {
  const absPath = path.join(runDir, relPath);
  fs.mkdirSync(path.dirname(absPath), { recursive: true });
  try {
    if (selector) {
      try {
        const presence = evalJson(selectorPresence(selector), runDir, 200_000);
        if (presence && presence.matchCount > 0) runBrowser(['scrollintoview', selector], { runDir });
      } catch (e) { /* best-effort; screenshot the viewport as-is */ }
    }
    runBrowser(['screenshot', absPath], { runDir });
    return fs.existsSync(absPath) ? relPath : null;
  } catch (error) {
    appendLog(runDir, `\nRepair screenshot error: ${error.message || error}\n`);
    return null;
  }
}

// The recipe as it was run, for the diagnosis input. Pure structural echo —
// carries no measurement.
function failedRecipeOf(capture, type, id) {
  const action = defaultAction(capture, type);
  let arm = null;
  try { arm = defaultArm(capture, type, id); } catch (e) { arm = null; }
  return {
    type,
    selector: capture.selector || capture.target || capture.root || selectorFromAction(action) || null,
    root: capture.root || null,
    action: typeof action === 'string' ? action : (action ? JSON.stringify(action) : null),
    arm,
    beforeAction: capture.beforeAction || capture.setupAction || null,
    waitMs: capture.waitMs == null ? 1200 : Number(capture.waitMs),
  };
}

// A light, honest slice of map.json for the failed capture (design §2). Best
// effort: where the selector shows up in the map, plus the planner's grouping.
function mapSubtreeFor(map, capture, selector) {
  const inList = (arr, key) => Array.isArray(arr) && arr.some(item => {
    const v = typeof item === 'string' ? item : (item && (item[key] || item.sel || item.host));
    return v && selector && String(v) === String(selector);
  });
  return {
    group: capture.group || null,
    label: capture.label || null,
    section: (Array.isArray(map.splitReveals) && (map.splitReveals.find(r => r.host === selector) || {}).section) || null,
    fromSplitReveal: inList(map.splitReveals, 'host'),
    inHoverCandidates: Array.isArray(map.hoverCandidates) && map.hoverCandidates.includes(selector),
    inCssHovers: inList(map.cssHovers, 'sel'),
  };
}

// Assemble the diagnosis input (design §2). Reuses Part 1 cause + causeSignals
// VERBATIM — the loop consumes the classifier's verdict, it does not re-diagnose.
function buildRepairInput({ capture, type, id, url, viewport, result, attempt, screenshot, repairContext, map, attemptHistory }) {
  return {
    captureId: id,
    attempt,
    url,
    viewport,
    failure: {
      status: result.status,
      reason: String(result.error || result.summary || '').replace(/\s+/g, ' ').trim(),
      cause: result.cause || null,
      causeSignals: result.causeSignals || null,
    },
    failedRecipe: failedRecipeOf(capture, type, id),
    screenshot,
    mapSubtree: mapSubtreeFor(map || {}, capture, capture.root || capture.selector || null),
    repairContext,
    attemptHistory: Array.isArray(attemptHistory) ? attemptHistory : [],
  };
}

function repairArtifactPath(runDir, id, attempt, ext) {
  return path.join(runDir, 'repair', `${id}.attempt-${attempt}.${ext}`);
}

function writeRepairInput(runDir, id, attempt, input) {
  const file = repairArtifactPath(runDir, id, attempt, 'input.json');
  writeJson(file, input);
  return file;
}

// Recipe-action vocabulary a precondition_action may use — exactly what
// runAction() already understands. The provider cannot inject anything else.
const REPAIR_ACTION_VERBS = ['click', 'dblclick', 'hover', 'focus', 'scrollintoview', 'wait', 'eval', 'press', 'scroll', 'mouse'];

function validRecipeStep(step) {
  if (step && typeof step === 'object') return Boolean(step.eval || step.waitMs != null || step.command);
  if (typeof step !== 'string' || !step.trim()) return false;
  try { return REPAIR_ACTION_VERBS.includes(splitAction(step).command); } catch (e) { return false; }
}

// Validate the provider's structured output against the closed contract (§3).
// An invalid/unparseable response is the caller's signal to fail safe to
// terminal_give_up(provider_error) — the loop never acts on garbage.
function validateRepairOutput(raw) {
  if (!raw || typeof raw !== 'object') return { valid: false, error: 'output is not an object' };
  const action = raw.action;
  if (!action || typeof action !== 'object' || !REPAIR_ACTION_KINDS.includes(action.kind)) {
    return { valid: false, error: `invalid action.kind: ${action && action.kind}` };
  }
  const kind = action.kind;
  if ((kind === 'retarget_selector' || kind === 'use_other_instance') && !action.selector && action.nth == null) {
    return { valid: false, error: `${kind} needs selector or nth` };
  }
  if (kind === 'scroll_into_view' && !action.selector) return { valid: false, error: 'scroll_into_view needs selector' };
  if (kind === 'precondition_action') {
    if (!Array.isArray(action.actions) || !action.actions.length) return { valid: false, error: 'precondition_action needs actions[]' };
    if (!action.actions.every(validRecipeStep)) return { valid: false, error: 'precondition_action has an unrecognized step' };
  }
  if (kind === 'retarget_iframe' && !action.frameSelector && !action.url) return { valid: false, error: 'retarget_iframe needs frameSelector or url' };

  let confidence = Number(raw.confidence);
  if (!Number.isFinite(confidence)) confidence = 0;
  confidence = Math.max(0, Math.min(1, confidence));
  const rootCause = REPAIR_ROOT_CAUSES.includes(raw.rootCause) ? raw.rootCause : 'ambiguous';
  const sc = (raw.successCriterion && typeof raw.successCriterion === 'object') ? raw.successCriterion : { expect: 'moved' };
  if (!['moved', 'status_ok_or_check'].includes(sc.expect)) sc.expect = 'moved';
  return {
    valid: true,
    repair: {
      diagnosis: String(raw.diagnosis || ''),
      rootCause,
      confidence,
      action,
      successCriterion: sc,
      abortCriterion: raw.abortCriterion || null,
    },
  };
}

// Prepend recipe steps to whichever pre-trigger action the recipe will run
// (setupAction || beforeAction), so a precondition/scroll repair actually fires.
function prependBeforeAction(clone, steps) {
  const active = clone.setupAction != null ? 'setupAction' : 'beforeAction';
  const existing = clone[active];
  const tail = existing == null ? [] : (Array.isArray(existing) ? existing : [existing]);
  clone[active] = steps.concat(tail);
}

// Apply a validated repair action to a CLONE of the capture (design §3). Every
// non-terminal action reduces to selector edits + the runAction vocabulary — no
// measurement, no new browser primitive. Stateful kinds set `fresh:true` (M1).
function applyRepair(capture, type, action) {
  const clone = JSON.parse(JSON.stringify(capture));
  const kind = action.kind;
  if (kind === 'retarget_selector' || kind === 'use_other_instance') {
    if (action.selector) {
      clone.root = action.selector;
      clone.selector = action.selector;
      clone.scrollTarget = action.selector;
      delete clone.target;
      delete clone.action;   // let defaultAction/defaultArm rebuild from the new selector
      delete clone.arm;
    }
    if (action.nth != null) clone.repairNth = action.nth;   // advisory; selector is authoritative
  } else if (kind === 'scroll_into_view') {
    prependBeforeAction(clone, [`scrollintoview ${action.selector}`, 'wait 300']);
    clone.fresh = true;
  } else if (kind === 'precondition_action') {
    prependBeforeAction(clone, action.actions.slice());
    clone.fresh = true;
  } else if (kind === 'retarget_iframe') {
    if (action.url) clone.url = action.url;
    clone.fresh = true;
  }
  return clone;
}

// Did the re-measured ENGINE result meet the machine-checked criterion (§3)?
// Reads status/movedSelectors only — never the model's self-report.
function meetsSuccess(result, criterion) {
  const okish = result && (result.status === 'ok' || result.status === 'check');
  if (!okish) return false;
  if (!criterion || criterion.expect === 'status_ok_or_check') return true;
  if (criterion.onSelector) {
    const moved = result.movedSelectors || [];
    const want = String(criterion.onSelector);
    return moved.some(s => s && (s.includes(want) || want.includes(s)));
  }
  return true;
}

// The (status, cause, occludedBy) triple used for repeated-identical detection
// (design §4.3): a repair that reproduces a prior attempt's triple is not
// converging, so the loop stops rather than burning more retries.
function resultTriple(result) {
  const occ = (result && result.causeSignals && result.causeSignals.occludedBy) || '';
  return `${result && result.status}|${(result && result.cause) || ''}|${occ}`;
}

function normalizeTerminalCause(cause) {
  return TERMINAL_CAUSES.includes(cause) ? cause : 'needs_human';
}

// The repair loop (design §1, §4). Pure orchestration over INJECTED effects so
// it is testable with no browser and no model (env supplies the stubs):
//   env = { log, screenshot(selector, relPath), repairContext(selector),
//           writeInput(input, attempt), callProvider(inputPath),
//           recapture(clonedCapture, type, id, fresh) -> engine result }
//   ctx = { capture, type, id, url, viewport, map, result, config, budget }
// Returns { result, repair, origin }. `result` is the engine-measured verdict
// to push (the original failure unless a repair genuinely succeeded); `repair`
// is the accounting block; the LLM never touches `result.status`.
function runRepairLoop(env, ctx) {
  const { config, budget } = ctx;
  const attempts = [];          // accounting + attemptHistory fed back to provider
  const seenTriples = [resultTriple(ctx.result)];
  let current = ctx.result;     // latest failed engine result
  let final = ctx.result;       // pushed result (engine-measured)
  let origin = 'first-try';
  let outcome = 'unrepaired';
  let winningAction = null;
  let terminalCause = null;

  for (let attempt = 1; attempt <= config.maxRetries; attempt++) {
    if (budget.remaining() <= 0) { env.log(`repair budget exhausted; stopping ${ctx.id}`); break; }
    budget.spend();

    const sel = current.root || ctx.failSelector || (current.causeSignals && current.causeSignals.selector) || null;
    const relShot = `repair/${ctx.id}.attempt-${attempt}.png`;
    const screenshot = env.screenshot(sel, relShot);
    const repairContext = env.repairContext(sel);
    const input = buildRepairInput({
      capture: ctx.capture, type: ctx.type, id: ctx.id, url: ctx.url, viewport: ctx.viewport,
      result: current, attempt, screenshot, repairContext, map: ctx.map, attemptHistory: attempts,
    });
    const inputPath = env.writeInput(input, attempt);
    const validated = validateRepairOutput(env.callProvider(inputPath));

    if (!validated.valid) {
      env.log(`repair ${ctx.id} attempt ${attempt}: invalid provider output (${validated.error}) -> terminal`);
      outcome = 'terminal'; terminalCause = 'provider_error';
      attempts.push({ action: 'terminal_give_up', params: { terminalCause: 'provider_error', error: validated.error }, confidence: null, resultStatus: null, resultCause: null });
      break;
    }

    const repair = validated.repair;
    const kind = repair.action.kind;

    if (kind === 'terminal_give_up') {
      outcome = 'terminal'; terminalCause = normalizeTerminalCause(repair.action.terminalCause);
      attempts.push({ action: kind, params: repair.action, confidence: repair.confidence, resultStatus: null, resultCause: null });
      env.log(`repair ${ctx.id} attempt ${attempt}: provider terminal_give_up(${terminalCause})`);
      break;
    }

    if (repair.confidence < config.confidenceFloor) {
      env.log(`repair ${ctx.id} attempt ${attempt}: confidence ${repair.confidence} < floor ${config.confidenceFloor}; not spending a retry`);
      outcome = 'unrepaired';
      final.lowConfidenceDiagnosis = repair.diagnosis || null;
      attempts.push({ action: kind, params: repair.action, confidence: repair.confidence, resultStatus: 'skipped-low-confidence', resultCause: null });
      break;
    }

    const fresh = isStatefulRepairKind(kind);
    const cloned = applyRepair(ctx.capture, ctx.type, repair.action);
    let recaptured;
    try {
      recaptured = env.recapture(cloned, ctx.type, ctx.id, fresh);
    } catch (error) {
      recaptured = { id: ctx.id, type: ctx.type, status: 'error', error: String(error.message || error), findings: 0, cause: 'other' };
    }
    attempts.push({ action: kind, params: repair.action, confidence: repair.confidence, resultStatus: recaptured.status, resultCause: recaptured.cause || null });

    if (meetsSuccess(recaptured, repair.successCriterion)) {
      outcome = 'ok-after-repair'; winningAction = kind; origin = 'after-repair';
      recaptured.page = final.page;   // preserve page provenance shape
      final = recaptured;
      env.log(`repair ${ctx.id} attempt ${attempt}: ${kind} succeeded -> ${recaptured.status}`);
      break;
    }

    const triple = resultTriple(recaptured);
    if (seenTriples.includes(triple)) {
      env.log(`repair ${ctx.id} attempt ${attempt}: repeated-identical (${triple}); not converging -> terminal`);
      outcome = 'terminal';
      // Not converging: honest terminal. Inert if nothing animatable was found.
      const animatable = repairContext && repairContext.animatableHere
        && (repairContext.animatableHere.selfHover || repairContext.animatableHere.pseudoHover
          || repairContext.animatableHere.childAnimated || repairContext.animatableHere.scrollTriggerBound);
      const occluded = recaptured.causeSignals && recaptured.causeSignals.occludedBy;
      terminalCause = (!animatable && !occluded) ? 'genuinely_inert' : 'needs_human';
      current = recaptured;
      break;
    }
    seenTriples.push(triple);
    current = recaptured;
  }

  const repairBlock = {
    attempted: true,
    attempts,
    winningAction,
    outcome,
    terminalCause: outcome === 'terminal' ? terminalCause : null,
  };
  return { result: final, repair: repairBlock, origin };
}

// External-command provider transport (design §5, mirrors runBrowser): run
// `<command> <input.json path>`; the command writes its output JSON and prints
// that path on stdout. Returns the parsed object, or null on any failure (the
// caller maps null -> terminal_give_up(provider_error)). Never throws.
function invokeRepairProvider(command, inputPath, runDir) {
  try {
    const res = spawnSync(`${command} ${shellQuote(inputPath)}`, {
      cwd: process.cwd(),
      shell: true,
      encoding: 'utf8',
      maxBuffer: DEFAULT_MAX_OUTPUT + 200_000,
    });
    if (res.status !== 0) {
      if (runDir) appendLog(runDir, `\nRepair provider exited ${res.status}: ${(res.stderr || '').trim()}\n`);
      return null;
    }
    const printed = String(res.stdout || '').trim().split('\n').filter(Boolean).pop();
    if (!printed) return null;
    const candidates = [
      path.isAbsolute(printed) ? printed : null,
      path.resolve(process.cwd(), printed),
      path.resolve(path.dirname(inputPath), printed),
    ].filter(Boolean);
    const outPath = candidates.find(p => fs.existsSync(p));
    if (!outPath) {
      if (runDir) appendLog(runDir, `\nRepair provider output not found at: ${printed}\n`);
      return null;
    }
    return JSON.parse(fs.readFileSync(outPath, 'utf8'));
  } catch (error) {
    if (runDir) appendLog(runDir, `\nRepair provider error: ${error.message || error}\n`);
    return null;
  }
}

function shellQuote(value) {
  return `'${String(value).replace(/'/g, `'\\''`)}'`;
}

function loadManifest(runDir, manifestPath) {
  let file = manifestPath ? path.resolve(manifestPath) : path.join(runDir, 'manifest.json');
  if (manifestPath && !fs.existsSync(file) && !path.isAbsolute(manifestPath)) {
    file = path.join(runDir, manifestPath);
  }
  if (!fs.existsSync(file)) throw new Error(`Manifest not found: ${file}`);
  return { file, manifest: readJson(file) };
}

function normalizeViewport(manifest, flags = {}) {
  if (flags.viewport) return flags.viewport;
  if (Array.isArray(manifest.viewport) && manifest.viewport.length === 2) {
    return [Number(manifest.viewport[0]), Number(manifest.viewport[1])];
  }
  return DEFAULT_VIEWPORT;
}

function openPage(runDir, url, viewport, initScripts = [ENGINE], options = {}) {
  const delayMs = Math.max(0, finiteNumber(options.openDelayMs, DEFAULT_OPEN_DELAY_MS));
  if (lastOpenAt && delayMs) {
    const remaining = delayMs - (Date.now() - lastOpenAt);
    if (remaining > 0) sleepMs(remaining);
  }
  runBrowser(['close', '--all'], { runDir });
  sleepMs(350);
  const args = ['open', url, '--headed'];
  for (const script of initScripts) args.push('--init-script', script);
  runBrowser(args, { runDir });
  lastOpenAt = Date.now();
  runBrowser(['set', 'viewport', String(viewport[0]), String(viewport[1])], { runDir });
}

function closeBrowser(runDir) {
  try {
    runBrowser(['close', '--all'], { runDir });
  } catch (error) {
    appendLog(runDir, `\nClose warning: ${error.message}\n`);
  }
}

function writeInitialManifest(runDir, manifest) {
  const existing = path.join(runDir, 'manifest.json');
  if (fs.existsSync(existing)) return readJson(existing);
  writeJson(existing, manifest);
  return manifest;
}

function splitAction(action) {
  const text = String(action || '').trim();
  const match = text.match(/^(\S+)(?:\s+([\s\S]*))?$/);
  if (!match) throw new Error('Empty capture action');
  return { command: match[1], rest: (match[2] || '').trim() };
}

function selectorFromAction(action) {
  if (!action) return null;
  const { command, rest } = splitAction(action);
  if (['click', 'dblclick', 'hover', 'focus', 'scrollintoview'].includes(command)) return rest;
  return null;
}

// Human label for the real action a capture performs (hover/click/...), used in
// preflight + failure messages so a hover/click failure isn't mislabeled
// "scroll target". Prefers the action verb, then the capture type, then the
// caller-supplied fallback. Also feeds Part 0 failure-cause bucketing.
const POINTER_ACTIONS = ['click', 'dblclick', 'hover', 'focus'];
function actionLabel(action, type, fallback = 'target') {
  const verb = (item) => {
    if (item && typeof item === 'object') return item.command || null;
    try { return item != null ? splitAction(item).command : null; } catch { return null; }
  };
  // A capture action can be a compound array (e.g. ["wait 100", "hover .x"]);
  // the meaningful verb is the pointer action, wherever it sits.
  for (const item of Array.isArray(action) ? action : [action]) {
    const command = verb(item);
    if (command && POINTER_ACTIONS.includes(command)) return command;
  }
  if (type && POINTER_ACTIONS.includes(type)) return type;
  return fallback;
}

function runAction(action, runDir) {
  if (!action) return;
  if (Array.isArray(action)) {
    for (const item of action) runAction(item, runDir);
    return;
  }
  if (typeof action === 'object') {
    if (action.eval) {
      evalStatement(action.eval, runDir);
    } else if (action.waitMs != null) {
      runBrowser(['wait', String(action.waitMs)], { runDir });
    } else if (action.command) {
      runAction([action.command, action.selector, action.value].filter(Boolean).join(' '), runDir);
    } else {
      throw new Error(`Unsupported action object: ${JSON.stringify(action)}`);
    }
    return;
  }

  const { command, rest } = splitAction(action);
  if (['click', 'dblclick', 'hover', 'focus', 'scrollintoview'].includes(command)) {
    if (!rest) throw new Error(`Action "${command}" requires a selector`);
    runBrowser([command, rest], { runDir });
  } else if (command === 'wait') {
    runBrowser(['wait', rest || '0'], { runDir });
  } else if (command === 'eval') {
    evalStatement(rest, runDir);
  } else if (command === 'press') {
    runBrowser(['press', rest], { runDir });
  } else if (command === 'scroll') {
    runBrowser(['scroll', ...rest.split(/\s+/).filter(Boolean)], { runDir });
  } else if (command === 'mouse') {
    runBrowser(['mouse', ...rest.split(/\s+/).filter(Boolean)], { runDir });
  } else {
    throw new Error(`Unsupported action command: ${command}`);
  }
}

function captureId(capture, index) {
  return slugify(capture.id || `capture-${index + 1}`);
}

function captureType(capture) {
  return String(capture.type || (capture.action ? splitAction(capture.action).command : 'manual')).toLowerCase();
}

function defaultAction(capture, type) {
  if (capture.action) return capture.action;
  const target = capture.target || capture.selector || capture.root;
  if (!target) return null;
  if (type === 'click') return `click ${target}`;
  if (type === 'hover') return `hover ${target}`;
  if (type === 'scroll' || type === 'scroll-reveal') return `scrollintoview ${target}`;
  return null;
}

function defaultArm(capture, type, id) {
  if (capture.arm === false) return null;
  if (capture.arm) return capture.arm;
  const target = capture.root || capture.selector || selectorFromAction(capture.action);
  if (!target) throw new Error(`Capture "${id}" needs root, selector, action, or arm`);
  const trigger = type === 'click' ? 'manual' : (type === 'scroll-reveal' ? 'scroll' : type);
  return `window.__cap.scan(${JSON.stringify(target)}, { trigger: ${JSON.stringify(trigger)}, captureSource: ${JSON.stringify(id)} })`;
}

function bootSelectorsFor(capture) {
  const boot = capture.boot || {};
  const sels = boot.selectors || capture.selectors || [];
  return Array.isArray(sels) ? sels.filter(Boolean) : [];
}

function bootInitFile(capture, id) {
  const boot = Object.assign({}, capture.boot || {});
  if (capture.selectors) boot.selectors = capture.selectors;
  if (capture.ms != null) boot.ms = capture.ms;
  if (capture.max != null) boot.max = capture.max;
  if (!boot.ms) boot.ms = capture.waitMs ? Math.max(100, Number(capture.waitMs) - 300) : 4000;
  const file = path.join(os.tmpdir(), `motion-decompile-boot-${process.pid}-${id}.js`);
  fs.writeFileSync(file, `window.__capAutoBoot = ${JSON.stringify(boot, null, 2)};\n`);
  return { file, boot };
}

function saveTimeline(runDir, id, timeline) {
  const file = path.join(runDir, 'timelines', `${id}.json`);
  writeJson(file, timeline);
  return file;
}

function statusForTimeline(timeline) {
  const moved = timeline?.meta?.elementsMoved ?? timeline?.findings?.length ?? 0;
  if (!Number(moved)) return 'empty';
  const stop = timeline?.meta?.terminationReason || '';
  if (/maxDuration|manualDump/.test(stop)) return 'check';
  return 'ok';
}

function timelineResult(runDir, id, type, file, timeline) {
  return {
    id,
    type,
    status: statusForTimeline(timeline),
    file,
    timelineRef: path.relative(runDir, file),
    summary: timeline.summary,
    findings: timeline.findings?.length || 0,
    // The selectors that actually moved (for the repair successCriterion
    // onSelector check). In-memory only; not serialized to capture-results.json.
    movedSelectors: Array.isArray(timeline.findings) ? timeline.findings.map(f => f && f.selector).filter(Boolean) : [],
    stop: timeline.meta?.terminationReason || null,
  };
}

// The settle->scrollintoview->arm->trigger->wait->dump recipe, run against the
// currently-open page. Shared verbatim by the first-try capture path and the
// repair re-run, so no second measurement path exists (design §1). Assumes a
// page is already open and ready; never opens or manages reuse state.
function executeRecipe(runDir, capture, type, id) {
  runMaybeAction(capture.setupAction || capture.beforeAction, runDir);
  const action = defaultAction(capture, type);
  const actionSelector = selectorFromAction(action);
  const scrollTarget = capture.scrollTarget || capture.root || actionSelector;
  const preflights = [];
  if (scrollTarget && type !== 'scroll' && type !== 'scroll-reveal') {
    const presence = preflightPresence(runDir, scrollTarget, actionLabel(action, type, 'scroll target'), capture);
    if (presence) preflights.push(presence);
    runBrowser(['scrollintoview', scrollTarget], { runDir });
    runBrowser(['wait', String(capture.settleMs || 250)], { runDir });
  }
  if (type === 'hover') {
    runBrowser(['mouse', 'move', '1', '1'], { runDir });
  }
  const arm = defaultArm(capture, type, id);
  if (arm) evalStatement(arm, runDir);
  const actionPreflight = preflightAction(runDir, action, capture);
  if (actionPreflight) preflights.push(actionPreflight);
  if (action) runAction(action, runDir);
  const waitMs = capture.waitMs == null ? 1200 : Number(capture.waitMs);
  runBrowser(['wait', String(waitMs)], { runDir });
  const timeline = evalJson('(() => window.__cap.dump({ copy: false }))()', runDir);
  const file = saveTimeline(runDir, id, timeline);
  const result = timelineResult(runDir, id, type, file, timeline);
  if (preflights.length) result.preflight = preflights.length === 1 ? preflights[0] : preflights;
  return result;
}

function captureStrategy(manifest = {}, flags = {}) {
  const strategy = String(flags.captureStrategy || manifest.captureStrategy || 'reuse-page');
  if (!['reuse-page', 'fresh'].includes(strategy)) {
    throw new Error(`Invalid captureStrategy "${strategy}". Use "reuse-page" or "fresh".`);
  }
  return strategy;
}

function captureGroupConfig(manifest = {}, group) {
  const groups = manifest.captureGroups || manifest.groups || {};
  return group && groups && typeof groups === 'object' ? (groups[group] || {}) : {};
}

function defaultCaptureGroup(type) {
  if (type === 'click' || type === 'dblclick') return 'stateful-interactions';
  return 'main-page-after-intro';
}

function reusableCaptureGroup(capture, type) {
  return capture.group || defaultCaptureGroup(type);
}

function captureCanReuse(manifest, flags, capture, type) {
  if (captureStrategy(manifest, flags) !== 'reuse-page') return false;
  if (type === 'boot' || type === 'load') return false;
  if (capture.fresh === true || capture.reusePage === false) return false;
  if (capture.fresh === false || capture.reusePage === true) return true;
  if (type === 'click' || type === 'dblclick') return Boolean(capture.resetAction);
  return true;
}

function reusablePageKey(url, viewport, group) {
  return JSON.stringify({ url, viewport, group });
}

function resetReusablePage(runDir, capture, type) {
  if (capture.resetScroll === false) return;
  if (type === 'manual' && capture.resetScroll !== true) return;
  evalStatement(`
    try {
      if (window.lenis && typeof window.lenis.scrollTo === 'function') window.lenis.scrollTo(0, { immediate: true, force: true });
    } catch (e) {}
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    document.documentElement.scrollTop = 0;
    document.body.scrollTop = 0;
  `, runDir);
  runBrowser(['wait', String(capture.reuseSettleMs || 250)], { runDir });
}

function runMaybeAction(action, runDir) {
  if (!action) return;
  runAction(action, runDir);
}

function runMap(runDir, manifest, flags = {}) {
  const viewport = normalizeViewport(manifest, flags);
  openPage(runDir, manifest.url, viewport, [ENGINE], { openDelayMs: openDelayMs(manifest, flags) });
  waitForPageReady(runDir, 'map', manifest, flags);
  runBrowser(['wait', String(manifest.initialWaitMs || 1000)], { runDir });
  let map = evalJson('(() => window.__cap.map())()', runDir);

  // Dominant-iframe handling. A site whose real content lives in one big iframe
  // maps as shell chrome only. For a SAME-ORIGIN frame the document is reachable
  // and IS the content, so re-point the whole run (map + capture) at its URL.
  // A CROSS-ORIGIN frame can't be followed silently — it is only flagged here;
  // the finding lands in report.md and the planner marks the run.
  const dom = map && map.dominantIframe;
  const canRetarget = dom && dom.src && !flags.noIframeRetarget && !flags._iframeRetargeted;
  if (canRetarget && dom.sameOrigin && dom.accessible) {
    const target = resolveUrl(dom.src, manifest.url);
    appendLog(runDir, `\nDominant same-origin iframe (${pctText(dom.areaRatio)} of viewport): re-targeting map+capture at ${target}\n`);
    const from = manifest.url;
    manifest.url = target;
    flags._iframeRetargeted = true;
    writeJson(path.join(runDir, 'manifest.json'), manifest);
    openPage(runDir, target, viewport, [ENGINE], { openDelayMs: openDelayMs(manifest, flags) });
    waitForPageReady(runDir, 'map:iframe-retarget', manifest, flags);
    runBrowser(['wait', String(manifest.initialWaitMs || 1000)], { runDir });
    map = evalJson('(() => window.__cap.map())()', runDir);
    map.retargetedFrom = { url: from, src: dom.src, areaRatio: dom.areaRatio };
  } else if (dom && dom.present !== false && dom.src) {
    appendLog(runDir, `\nDominant cross-origin iframe (${pctText(dom.areaRatio)} of viewport): primary content is ${dom.src}. Re-run motion-decompile against that URL.\n`);
  }

  writeJson(path.join(runDir, 'map.json'), map);
  appendLog(runDir, `\nSaved map: \`map.json\`\n`);
  return map;
}

function runCapture(runDir, manifest, manifestFile, flags = {}) {
  const viewport = normalizeViewport(manifest);
  const strategy = captureStrategy(manifest, flags);
  const captures = Array.isArray(manifest.captures) ? manifest.captures : [];
  if (!captures.length) throw new Error('Manifest has no captures.');
  writeJson(path.join(runDir, 'manifest.json'), manifest);
  appendLog(runDir, `\nUsing manifest: \`${manifestFile || path.join(runDir, 'manifest.json')}\`\n`);
  appendLog(runDir, `Capture strategy: \`${strategy}\`\n`);

  // Map context for the failure classifier (dominant-iframe + ScrollTrigger).
  const map = optionalJson(path.join(runDir, 'map.json'), {});
  const scrollTriggerPresent = Array.isArray(map.libs)
    && map.libs.some(l => /scrolltrigger/i.test(String(l)));

  // Probe a failed capture and attach a fixed-vocabulary `cause`. Live-probe
  // signals are preferred; on any probe failure we still classify from the
  // reason string + map context. Never throws into the capture loop.
  const attachCause = (result, capture, captureType, opts = {}) => {
    if (result.status === 'ok' || result.status === 'check' || result.status === 'skipped') return result;
    const isBoot = captureType === 'boot' || captureType === 'load';
    const selector = opts.selector !== undefined
      ? opts.selector
      : (capture.root || capture.selector || selectorFromAction(defaultAction(capture, captureType)) || null);
    const bootSelectors = isBoot ? bootSelectorsFor(capture) : [];
    let probe = null;
    if (opts.probe !== false && (selector || bootSelectors.length)) {
      probe = runFailureProbe(runDir, selector, bootSelectors);
    }
    result.cause = validCause(classifyFailure({
      result, type: captureType, probe, map, isBoot, scrollTriggerPresent,
    }));
    if (probe) {
      result.causeSignals = {
        found: probe.found, visible: probe.visible, zeroBox: probe.zeroBox,
        occludedBy: probe.occludedBy || undefined,
        hoverSelfAnimatable: probe.hoverSelfAnimatable,
        hoverPseudoAnimatable: probe.hoverPseudoAnimatable,
        pseudoHasTransition: probe.pseudoHasTransition,
        bootHostsTotal: isBoot ? probe.bootHosts.total : undefined,
        bootHostsBelowFold: isBoot ? probe.bootHosts.below : undefined,
        scrollTriggerPresent: isBoot ? scrollTriggerPresent : undefined,
      };
    }
    appendLog(runDir, `Cause for ${result.id}: \`${result.cause}\`\n`);
    return result;
  };

  const results = [];
  let currentPage = null;

  // ── Capture-repair loop wiring (design §1, §5). Inert when no provider is
  // configured: repairCfg === null means the loop never runs and soft-fail
  // behavior is byte-identical. ──
  const repairCfg = repairConfig(manifest, flags);
  const repairableCount = captures.filter(c => !(c.skip || c.enabled === false)).length;
  const repairBudgetTotal = repairCfg
    ? Math.min(repairCfg.budget != null ? repairCfg.budget : REPAIR_DEFAULTS.budgetMultiplier * repairableCount, REPAIR_DEFAULTS.budgetCeiling)
    : 0;
  let repairSpent = 0;
  const repairBudget = { total: repairBudgetTotal, spend: () => { repairSpent += 1; }, remaining: () => repairBudgetTotal - repairSpent };
  if (repairCfg) {
    appendLog(runDir, `\nRepair loop armed: cmd=\`${repairCfg.command}\` maxRetries=${repairCfg.maxRetries} budget=${repairBudgetTotal} causes=[${repairCfg.repairableCauses.join(', ')}]\n`);
  }

  // Re-run the recipe for a repair. M1 (design §11): stateful repairs (fresh)
  // re-open a clean page so the precondition starts from REST, and clear the
  // reuse state so the mutation cannot leak into later reuse-page captures.
  const recaptureForRepair = (cloned, type, id, fresh) => {
    if (fresh) {
      const rurl = cloned.url || manifest.url;
      openPage(runDir, rurl, viewport, [ENGINE], { openDelayMs: openDelayMs(manifest, flags, cloned) });
      waitForPageReady(runDir, `repair:${id}:open`, manifest, flags, cloned);
      runBrowser(['wait', String(cloned.initialWaitMs || manifest.captureInitialWaitMs || 1000)], { runDir });
      currentPage = null;   // M1: a fresh stateful repair must not leak into N+1
    }
    const r = executeRecipe(runDir, cloned, type, id);
    const cloneSel = cloned.root || selectorFromAction(defaultAction(cloned, type)) || cloned.selector || null;
    attachCause(r, cloned, type, { selector: cloneSel });
    return r;
  };

  const repairEnv = repairCfg ? {
    log: (msg) => appendLog(runDir, `\n[repair] ${msg}\n`),
    screenshot: (sel, relPath) => captureRepairScreenshot(runDir, sel, relPath),
    repairContext: (sel) => runRepairContext(runDir, sel),
    writeInput: (input, attempt) => writeRepairInput(runDir, input.captureId, attempt, input),
    callProvider: (inputPath) => invokeRepairProvider(repairCfg.command, inputPath, runDir),
    recapture: recaptureForRepair,
  } : null;

  // Returns the result object to push. Runs the repair loop only for a
  // repairable empty/error; otherwise stamps origin and returns the result
  // unchanged.
  const maybeRepair = (result, capture, type, id, failSelector) => {
    const repairable = repairCfg
      && (result.status === 'empty' || result.status === 'error')
      && repairCfg.repairableCauses.includes(result.cause);
    if (repairable) {
      const out = runRepairLoop(repairEnv, {
        capture, type, id, url: capture.url || manifest.url, viewport, map,
        result, config: repairCfg, budget: repairBudget, failSelector,
      });
      out.result.origin = out.origin;
      out.result.repair = out.repair;
      return out.result;
    }
    if (!result.origin) result.origin = 'first-try';
    return result;
  };

  for (const [index, capture] of captures.entries()) {
    const id = captureId(capture, index);
    const type = captureType(capture);
    if (capture.skip || capture.enabled === false) {
      appendLog(runDir, `\n## Capture ${id}\n\nSkipped: ${capture.reason || 'marked skipped'}\n`);
      results.push({
        id,
        type,
        status: 'skipped',
        summary: capture.skipReason || capture.reason || 'marked skipped',
        findings: 0,
        stop: 'skipped',
      });
      continue;
    }

    try {
      const url = capture.url || manifest.url;
      const waitMs = capture.waitMs == null ? null : Number(capture.waitMs);
      const canReuse = captureCanReuse(manifest, flags, capture, type);
      const group = canReuse ? reusableCaptureGroup(capture, type) : null;
      const groupConfig = canReuse ? captureGroupConfig(manifest, group) : {};
      const pageKey = canReuse ? reusablePageKey(url, viewport, group) : null;
      appendLog(runDir, `\n## Capture ${id}\n\nType: \`${type}\`\n`);

      if (type === 'boot' || type === 'load') {
        currentPage = null;
        const init = bootInitFile(capture, id);
        try {
          openPage(runDir, url, viewport, [init.file, ENGINE], { openDelayMs: openDelayMs(manifest, flags, capture) });
          runBrowser(['wait', String(waitMs == null ? init.boot.ms + 300 : waitMs)], { runDir });
          waitForPageReady(runDir, `capture:${id}:after-boot`, manifest, flags, capture);
          const timeline = evalJson('(() => window.__cap.bootDump({ copy: false }))()', runDir);
          const file = saveTimeline(runDir, id, timeline);
          const result = timelineResult(runDir, id, type, file, timeline);
          result.page = { strategy: 'fresh', opened: true, group: null, seededReusablePage: false };
          attachCause(result, capture, type);
          result.origin = 'first-try';   // boot/load captures are not routed to the repair loop
          results.push(result);
          if (strategy === 'reuse-page' && capture.seedReuse !== false && url === manifest.url) {
            const seededGroup = capture.seedGroup || 'main-page-after-intro';
            currentPage = {
              key: reusablePageKey(url, viewport, seededGroup),
              url,
              group: seededGroup,
              seededBy: id,
              setupDone: false,
            };
            result.page.seededReusablePage = true;
            result.page.seedGroup = seededGroup;
          }
        } finally {
          fs.rmSync(init.file, { force: true });
        }
        continue;
      }

      const opened = !canReuse || !currentPage || currentPage.key !== pageKey;
      if (opened) {
        openPage(runDir, url, viewport, [ENGINE], { openDelayMs: openDelayMs(manifest, flags, capture) });
        currentPage = canReuse ? { key: pageKey, url, group, seededBy: null, setupDone: false } : null;
        waitForPageReady(runDir, `capture:${id}:open`, manifest, flags, capture);
        runBrowser(['wait', String(capture.initialWaitMs || groupConfig.initialWaitMs || manifest.captureInitialWaitMs || 1000)], { runDir });
        if (canReuse) {
          runMaybeAction(groupConfig.setupAction || groupConfig.action, runDir);
          currentPage.setupDone = true;
        }
      } else {
        appendLog(runDir, `Reusing page group \`${group}\` for ${id}.\n`);
        if (canReuse && currentPage && !currentPage.setupDone) {
          runMaybeAction(groupConfig.setupAction || groupConfig.action, runDir);
          currentPage.setupDone = true;
        }
      }

      if (canReuse) resetReusablePage(runDir, Object.assign({}, groupConfig, capture), type);

      const action = defaultAction(capture, type);
      const actionSelector = selectorFromAction(action);
      const scrollTarget = capture.scrollTarget || capture.root || actionSelector;
      const result = executeRecipe(runDir, capture, type, id);
      result.page = {
        strategy: canReuse ? 'reuse-page' : 'fresh',
        opened,
        group,
        seededBy: currentPage && currentPage.group === group ? currentPage.seededBy : null,
      };
      const recipeSelector = capture.root || actionSelector || scrollTarget || null;
      attachCause(result, capture, type, { selector: recipeSelector });
      results.push(maybeRepair(result, capture, type, id, recipeSelector));
      if (capture.resetAction) {
        try {
          runAction(capture.resetAction, runDir);
        } catch (resetError) {
          appendLog(runDir, `\nReset action failed after ${id}: ${resetError.message || resetError}\n`);
          currentPage = null;
        }
      }
    } catch (error) {
      const message = error.message || String(error);
      appendLog(runDir, `\nCapture failed: ${message}\n`);
      const errorResult = {
        id,
        type,
        status: 'error',
        summary: 'capture failed before a timeline could be saved',
        findings: 0,
        stop: 'error',
        error: message,
        pageState: error.state || undefined,
        page: {
          strategy: captureCanReuse(manifest, flags, capture, type) ? 'reuse-page' : 'fresh',
          group: captureCanReuse(manifest, flags, capture, type) ? reusableCaptureGroup(capture, type) : null,
        },
      };
      // Classify the failure. A blocked page can't be probed safely, so for a
      // fatal page-state error we classify from the reason string + map context.
      attachCause(errorResult, capture, type, { probe: !error.fatalPageState });
      // A non-fatal error (e.g. occlusion preflight) leaves the page usable, so
      // the repair loop can probe + re-run. A fatal page blocker cannot.
      const errSelector = capture.root || selectorFromAction(defaultAction(capture, type)) || capture.selector || null;
      const pushResult = error.fatalPageState ? errorResult : maybeRepair(errorResult, capture, type, id, errSelector);
      if (!pushResult.origin) pushResult.origin = 'first-try';
      results.push(pushResult);
      if (type === 'click' || type === 'dblclick' || capture.invalidatePageOnError === true) currentPage = null;
      if (error.fatalPageState) {
        for (const [offset, remaining] of captures.slice(index + 1).entries()) {
          const remainingId = captureId(remaining, index + 1 + offset);
          results.push({
            id: remainingId,
            type: captureType(remaining),
            status: 'skipped',
            summary: `aborted after page blocker: ${pageBlockerSummary(error.state)}`,
            findings: 0,
            stop: 'skipped',
          });
        }
        break;
      }
    }
  }

  writeJson(path.join(runDir, 'capture-results.json'), {
    capturedAt: new Date().toISOString(),
    count: results.length,
    results: results.map(result => ({
      id: result.id,
      type: result.type,
      status: result.status,
      timelineRef: result.timelineRef || (result.file ? path.relative(runDir, result.file) : null),
      summary: result.summary,
      findings: result.findings,
      stop: result.stop || null,
      error: result.error,
      cause: result.cause,
      causeSignals: result.causeSignals,
      preflight: result.preflight,
      pageState: result.pageState,
      page: result.page,
      // Repair provenance (design §6). origin is always present; repair is set
      // only when the loop ran. status above is ALWAYS the engine-measured
      // verdict — repair is metadata about how it was reached, never overrides.
      origin: result.origin || (result.status === 'skipped' ? undefined : 'first-try'),
      repair: result.repair,
      lowConfidenceDiagnosis: result.lowConfidenceDiagnosis,
    })),
  });
  appendLog(runDir, `\nSaved ${timelineCount(results)} timeline(s); ${results.length} capture result(s).\n`);
  return results;
}

function manifestPathForDecompile(runDir, manifestArg) {
  if (manifestArg) {
    let file = path.resolve(manifestArg);
    if (!fs.existsSync(file) && !path.isAbsolute(manifestArg)) file = path.join(runDir, manifestArg);
    if (!fs.existsSync(file)) throw new Error(`Manifest not found: ${file}`);
    return file;
  }
  const proposed = path.join(runDir, 'manifest.proposed.json');
  if (fs.existsSync(proposed)) return proposed;
  return path.join(runDir, 'manifest.json');
}

function runFromManifestFile(manifestFile, flags = {}) {
  const manifest = readJson(manifestFile);
  if (!manifest.url) throw new Error('Manifest needs a url.');
  const runDir = runDirFor(manifest.url, flags);
  ensureRunDir(runDir);
  try {
    writeJson(path.join(runDir, 'manifest.json'), manifest);
    appendLog(runDir, `Running full pipeline from ${manifestFile}`);
    const map = runMap(runDir, manifest, flags);
    const results = runCapture(runDir, manifest, manifestFile, flags);
    const spec = assembleSpec(runDir);
    buildReport(runDir);
    return { runDir, map, results, spec };
  } finally {
    if (!flags.keepOpen) closeBrowser(runDir);
  }
}

function scoutUrl(url, flags = {}) {
  const viewport = flags.viewport || DEFAULT_VIEWPORT;
  const runDir = runDirFor(url, flags);
  ensureRunDir(runDir);
  try {
    const manifest = writeInitialManifest(runDir, { url, viewport, captures: [] });
    appendLog(runDir, `Scouting ${url}`);
    const map = runMap(runDir, manifest, flags);
    const plan = planFromMap(runDir, flags);
    buildReport(runDir);
    return { runDir, map, plan };
  } finally {
    if (!flags.keepOpen) closeBrowser(runDir);
  }
}

function decompileRunDir(runDir, manifestArg, flags = {}) {
  ensureRunDir(runDir);
  const manifestFile = manifestPathForDecompile(runDir, manifestArg);
  const manifest = readJson(manifestFile);
  if (!manifest.url) throw new Error(`Manifest needs a url: ${manifestFile}`);
  try {
    writeJson(path.join(runDir, 'manifest.json'), manifest);
    appendLog(runDir, `Decompiling from ${manifestFile}`);
    const results = runCapture(runDir, manifest, manifestFile, flags);
    const spec = assembleSpec(runDir);
    buildReport(runDir);
    return { runDir, manifestFile, results, spec };
  } finally {
    if (!flags.keepOpen) closeBrowser(runDir);
  }
}

function decompileUrl(url, flags = {}) {
  const scout = scoutUrl(url, flags);
  const manifestFile = path.join(scout.runDir, 'manifest.proposed.json');
  const manifest = readJson(manifestFile);
  try {
    const results = runCapture(scout.runDir, manifest, manifestFile, flags);
    const spec = assembleSpec(scout.runDir);
    buildReport(scout.runDir);
    return { runDir: scout.runDir, map: scout.map, plan: scout.plan, manifestFile, results, spec };
  } finally {
    if (!flags.keepOpen) closeBrowser(scout.runDir);
  }
}

function optionalJson(file, fallback) {
  return fs.existsSync(file) ? readJson(file) : fallback;
}

function tableRow(cells) {
  return `| ${cells.map(cell => reportText(cell).replace(/\|/g, '\\|')).join(' | ')} |`;
}

function reportText(value) {
  return String(value == null ? '' : value)
    .replace(/\u2014/g, '-')
    .replace(/\r?\n/g, '<br>');
}

function plainStrings(value) {
  if (typeof value === 'string') return reportText(value);
  if (Array.isArray(value)) return value.map(plainStrings);
  if (value && typeof value === 'object') {
    return Object.fromEntries(Object.entries(value).map(([key, item]) => [key, plainStrings(item)]));
  }
  return value;
}

function seconds(value) {
  if (value == null || value === '') return 'unknown';
  if (typeof value === 'number') return `${value}s`;
  return String(value);
}

function sentence(value) {
  const text = reportText(value).trim();
  return text ? text[0].toUpperCase() + text.slice(1) : '';
}

function labelFromId(id) {
  return sentence(String(id || 'animation').replace(/[-_]+/g, ' '));
}

function selectorLabel(selector) {
  const text = String(selector || 'element');
  const cleaned = text
    .replace(/:nth-of-type\(\d+\)/g, '')
    .replace(/^[a-z]+\./, '')
    .replace(/^[#.]/, '')
    .replace(/[._-]+/g, ' ')
    .trim();
  return sentence(cleaned || text);
}

function propertyKeys(value) {
  if (!value || typeof value !== 'object') return [];
  return Object.keys(value).filter(key => value[key] !== undefined && value[key] !== null);
}

function mechanismFromProps(props) {
  const keys = propertyKeys(props).filter(key => key !== 'lazy');
  if (!keys.length) return 'motion';
  if (keys.some(key => ['x', 'y', 'z', 'xPercent', 'yPercent', 'scale', 'scaleX', 'scaleY', 'rotate', 'rotation'].includes(key))) {
    return 'transform';
  }
  return keys.join(', ');
}

function slugPart(value) {
  return slugify(String(value || '').replace(/[#.[\]"'=]/g, ' '));
}

function uniquePush(list, item) {
  if (!item || !item.id || list.some(existing => existing.id === item.id)) return;
  list.push(item);
}

function mapCaptureById(manifest) {
  const out = new Map();
  (manifest.captures || []).forEach((capture, index) => {
    out.set(captureId(capture, index), capture);
  });
  return out;
}

function timelineResults(runDir) {
  const saved = optionalJson(path.join(runDir, 'capture-results.json'), null);
  if (saved && Array.isArray(saved.results)) return saved.results;
  const dir = path.join(runDir, 'timelines');
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir)
    .filter(file => file.endsWith('.json'))
    .sort()
    .map(file => ({
      id: path.basename(file, '.json'),
      type: null,
      timelineRef: path.join('timelines', file),
    }));
}

function timelineCount(results) {
  return results.filter(result => result.timelineRef || result.file).length;
}

function relativeTimelineRef(runDir, result) {
  if (result.timelineRef) return result.timelineRef;
  if (result.file) return path.relative(runDir, result.file);
  if (result.status === 'error' || result.status === 'skipped') return null;
  return path.join('timelines', `${result.id}.json`);
}

function findingProperty(finding) {
  if (!finding) return { name: 'motion', value: null };
  const props = finding?.properties || {};
  const preferred = finding.leadProperty && props[finding.leadProperty]
    ? finding.leadProperty
    : Object.keys(props)[0];
  return { name: preferred || finding?.type || 'motion', value: preferred ? props[preferred] : null };
}

function stateForProperty(propName, value) {
  if (value === undefined || value === null) return {};
  return { [propName]: value };
}

function findingTiming(finding, prop) {
  return prop?.timing || finding?.timing || {};
}

function findingHasProperty(finding, prop) {
  return Boolean(finding?.properties && finding.properties[prop]);
}

function revealLikeTrigger(trigger) {
  return /^(boot|load|scroll|scroll-reveal)$/i.test(String(trigger || ''));
}

function preferredRevealFinding(findings) {
  return findings.find(finding => findingHasProperty(finding, 'transform'))
    || findings.find(finding => findingHasProperty(finding, 'opacity'))
    || null;
}

function boxOnlyTextReflowFindings(findings) {
  return findings.filter(finding => {
    const props = Object.keys(finding?.properties || {}).filter(key => finding.properties[key]);
    if (!props.length || !props.every(prop => prop === 'width' || prop === 'height')) return false;
    const haystack = [
      finding.selector,
      finding.locator?.shortSelector,
      finding.locator?.uniqueSelector,
      finding.locator?.text,
    ].filter(Boolean).join(' ').toLowerCase();
    return Boolean(finding.locator?.text)
      || /\b(p|h[1-6])\b|word|char|line|split|heading|title|headline|text/.test(haystack);
  });
}

function cubicBezier(value) {
  const text = String(value || '');
  return /^cubic-bezier\(/.test(text) ? text : null;
}

function confidenceFor(lead, timing, timeline) {
  const haystack = JSON.stringify(lead || {});
  if (haystack.includes('_approx3d')) return '_approx3d';
  const easing = String(timing?.easing || '');
  if (!easing || /unknown|verify/i.test(easing)) return 'unknown - verify';
  if (timeline?.meta?.trigger === 'load' && timeline?.meta?.terminationReason === 'stopped') return 'unknown - verify';
  return 'measured';
}

function chooseLeadFinding(timeline, trigger) {
  const findings = timeline.findings || [];
  if (!findings.length) return null;
  if (trigger === 'click' || trigger === 'manual') {
    const height = findings.find(finding => finding.properties && finding.properties.height);
    if (height) return height;
  }
  if (revealLikeTrigger(trigger)) {
    const reveal = preferredRevealFinding(findings);
    if (reveal) return reveal;
  }
  return findings.find(finding => {
    const prop = findingProperty(finding);
    return prop.value;
  }) || findings[0];
}

function summarizeStagger(stagger) {
  if (!stagger || !stagger.items) return null;
  return { items: stagger.items, ms: stagger.staggerMs ?? stagger.ms ?? null };
}

function maxTransitionMs(value) {
  const matches = String(value || '').match(/[\d.]+m?s/g) || [];
  const values = matches.map(item => item.endsWith('ms')
    ? parseFloat(item)
    : parseFloat(item) * 1000);
  return values.length ? Math.max(...values) : 700;
}

function captureSignature(capture) {
  return [
    capture.type || '',
    capture.root || '',
    capture.action || '',
    capture.boot ? JSON.stringify(capture.boot) : '',
  ].join('|');
}

function addPlannedCapture(state, capture) {
  const item = plainStrings(capture);
  const id = captureId(item, state.captures.length);
  const sig = captureSignature(item);
  if (state.ids.has(id) || state.signatures.has(sig)) return false;
  state.ids.add(id);
  state.signatures.add(sig);
  state.captures.push(item);
  return true;
}

function hoverPlanGroup(selector) {
  const s = String(selector || '').toLowerCase();
  if (/work.*(item|card|cover|link)|work_home/.test(s)) return { id: 'work-card-hover', priority: 10 };
  if (/wordmark|navbar_home_link/.test(s)) return { id: 'wordmark-hover', priority: 20 };
  if (/services_home_cta|services_home_arrows|services_home_cta_arrow/.test(s)) return { id: 'services-cta-hover', priority: 40 };
  if (/g_btn|btn|button|cta/.test(s)) return { id: 'primary-button-hover', priority: 30 };
  if (/arrow/.test(s)) return { id: 'arrow-row-hover', priority: 40 };
  if (/navbar|nav.*link/.test(s)) return { id: 'nav-link-hover', priority: 50 };
  if (/link/.test(s)) return { id: 'link-hover', priority: 60 };
  if (/menu/.test(s)) return { id: 'menu-hover', priority: 80 };
  return { id: 'misc-hover', priority: 90 };
}

function hoverSelectorScore(selector) {
  const s = String(selector || '').toLowerCase();
  let score = 0;
  if (/^#w-node-/.test(s)) score += 100;
  if (/^a[.#]|^button[.#]|^\[role="button"\]/.test(s)) score -= 20;
  if (/w-inline-block|g_btn_main|services_home_cta|work_home_item_link|navbar_btn_default/.test(s)) score -= 10;
  if (/^ul[.#]/.test(s)) score += 40;
  if (/^li[.#]/.test(s)) score += 12;
  if (/^span[.#]|^svg[.#]|^img[.#]/.test(s)) score += 18;
  if (/menu/.test(s)) score += 25;
  if (/lightbox|vimeo/.test(s)) score += 12;
  if (/container|contain|content|heading|text$/.test(s)) score += 8;
  return score;
}

function generatedSelector(selector) {
  return /^#w-node-/i.test(String(selector || ''));
}

function genericSelector(selector) {
  return /^(a|button|div|span|svg|img|li|ul|p|section|article|nav|header|footer)$/i.test(String(selector || '').trim());
}

function stackHasScrollTrigger(map) {
  return Array.isArray(map?.libs)
    && map.libs.some(item => /scrolltrigger/i.test(String(item)));
}

function selectorTag(selector) {
  const match = String(selector || '').trim().match(/^([a-z][a-z0-9-]*)\b/i);
  return match ? match[1].toLowerCase() : null;
}

function selectorClassTokens(selector) {
  const tokens = [];
  const re = /\.((?:\\.|[A-Za-z0-9_-])+)/g;
  let match;
  while ((match = re.exec(String(selector || '')))) {
    tokens.push(match[1].replace(/\\/g, ''));
  }
  return tokens;
}

function accordionBaseClass(token) {
  const cls = String(token || '');
  if (!/accordion|faq/i.test(cls)) return null;
  const suffix = '(?:top|header|head|heading|title|question|trigger|toggle|button|btn|label|icon|svg|content|bottom|panel|body|answer|text|wrap|inner)';
  const match = cls.match(new RegExp(`^(.+?(?:item|row|entry|faq|accordion))[-_]+${suffix}(?:[-_].*)?$`, 'i'));
  if (match && match[1]) return match[1];
  if (/(?:^|[-_])(item|row|entry)(?:$|[-_])|accordion|faq/i.test(cls)) return cls;
  return null;
}

function accordionRootFromSelector(selector) {
  for (const token of selectorClassTokens(selector)) {
    const base = accordionBaseClass(token);
    if (!base) continue;
    const tag = selectorTag(selector);
    if (token === base) {
      const rootTag = ['li', 'details', 'section', 'article', 'div'].includes(tag) ? tag : 'div';
      return `${rootTag}.${base}`;
    }
    const suffix = token.slice(base.length).match(/^[-_]+/)?.[0] || '-';
    return [`li.${base}`, `div.${base}`, `div.${base}${suffix}top`].join(', ');
  }
  return null;
}

function accordionRootBase(root) {
  for (const token of selectorClassTokens(root)) {
    const base = accordionBaseClass(token);
    if (base) return base;
  }
  return null;
}

function inferredAccordionToggleSelectors(selector, rootBase) {
  const out = [];
  const tag = selectorTag(selector);
  const clickTag = ['button', 'a'].includes(tag) ? tag : 'div';
  for (const token of selectorClassTokens(selector)) {
    const match = token.match(/^(.+?(?:item|row|entry|faq|accordion))([-_]+)(?:bottom|content|panel|body|answer)(?:[-_].*)?$/i);
    if (!match) continue;
    const base = match[1];
    if (rootBase && base !== rootBase) continue;
    const sep = match[2] || '-';
    for (const suffix of ['top', 'header', 'head', 'trigger', 'toggle', 'question', 'title']) {
      out.push(`${clickTag}.${base}${sep}${suffix}`);
    }
  }
  return out;
}

function cssHoverCoveredByParent(hover, map) {
  const selector = String(hover?.sel || '');
  const candidates = map.hoverCandidates || [];
  if (/work_home_(cover_deco|link_overlay|link_clip|aside_arrow|link_cover)/.test(selector) &&
      candidates.some(item => /work_home_item_link/.test(item))) {
    return 'covered by parent work-card-hover';
  }
  if (/navbar_btn_container|navbar_btn_text/.test(selector) &&
      candidates.some(item => /navbar_btn_default/.test(item))) {
    return 'covered by parent navbar button hover';
  }
  if (/^div\.g_btn_container/.test(selector) &&
      candidates.some(item => /a\.g_btn_main|services_home_cta/.test(item))) {
    return 'covered by parent button/CTA hover';
  }
  return null;
}

function inferAccordionRoot(map) {
  const selectors = [
    ...(map.cssHovers || []).map(item => item.sel),
    ...(map.hoverCandidates || []),
  ].filter(Boolean);
  const matches = selectors.filter(selector => /accordion|faq/i.test(selector) && !generatedSelector(selector) && !genericSelector(selector));
  if (!matches.length) return null;

  const roots = new Map();
  for (const selector of matches) {
    const root = accordionRootFromSelector(selector);
    if (!root || generatedSelector(root) || genericSelector(root)) continue;
    const item = roots.get(root) || { selector: root, count: 0 };
    item.count++;
    roots.set(root, item);
  }
  if (roots.size) {
    return [...roots.values()].map(item => {
      const s = item.selector.toLowerCase();
      let score = hoverSelectorScore(item.selector);
      score -= Math.min(30, item.count * 8);
      if (/item|row|entry|question|faq/.test(s)) score -= 35;
      if (/button|btn|trigger|toggle|top|header|heading|title|label|icon|svg|text|content|bottom|panel|body|answer/.test(s)) score += 30;
      return { selector: item.selector, score };
    }).sort((a, b) => a.score - b.score)[0].selector;
  }

  const scored = matches.map(selector => {
    const s = selector.toLowerCase();
    let score = hoverSelectorScore(selector);
    if (/item|row|entry|question|faq/.test(s)) score -= 25;
    if (/content|bottom|panel|body|answer/.test(s)) score += 55;
    if (/button|btn|trigger|toggle|top|header|heading|title|label|icon|svg|text/.test(s)) score += 25;
    if (/^button[.#]|^a[.#]|\[role="button"\]/.test(s)) score += 18;
    if (/^section[.#]|^div[.#]/.test(s)) score -= 5;
    return { selector, score };
  }).sort((a, b) => a.score - b.score);
  return scored[0].selector;
}

function inferAccordionAction(map, root) {
  const rawCandidates = [
    ...(map.hoverCandidates || []),
    ...(map.cssHovers || []).map(item => item.sel),
  ].filter(Boolean)
    .filter(selector => /accordion|faq/i.test(selector) && !generatedSelector(selector) && !genericSelector(selector));
  const rootBase = accordionRootBase(root);
  const candidates = [];
  const seen = new Set();
  const add = (selector, generated = false) => {
    if (!selector || seen.has(selector)) return;
    seen.add(selector);
    candidates.push({ selector, generated });
  };
  for (const selector of rawCandidates) {
    add(selector, false);
    for (const inferred of inferredAccordionToggleSelectors(selector, rootBase)) add(inferred, true);
  }
  const scored = candidates.map(item => {
    const s = item.selector.toLowerCase();
    let score = hoverSelectorScore(item.selector);
    if (/button|btn/.test(s)) score -= 75;
    if (/trigger|toggle/.test(s)) score -= item.generated ? 55 : 75;
    if (/top|header|head|heading|title|question/.test(s)) score -= item.generated ? 85 : 65;
    if (/icon|svg/.test(s)) score -= 35;
    if (/label|text/.test(s)) score -= 10;
    if (/content|bottom|panel|body|answer/.test(s)) score += 90;
    if (/^button[.#]|^a[.#]|\[role="button"\]/.test(s)) score -= 18;
    if (item.selector === root) score += 20;
    if (item.generated) score -= 5;
    return { selector: item.selector, score };
  }).sort((a, b) => a.score - b.score);
  return `click ${(scored[0] && scored[0].selector) || root}`;
}

function splitBootSelectors(map) {
  const hosts = [...new Set((map.splitReveals || [])
    .map(reveal => reveal.host)
    .filter(Boolean))];
  if (!hosts.length) return [];
  return [
    ...hosts.slice(0, 12),
    '.lines-split',
    '.words-split',
    '.chars-split',
    '[class*="lines-split"]',
    '[class*="words-split"]',
    '[class*="chars-split"]',
  ];
}

function splitRevealScrollCapture(reveal, index) {
  const root = reveal.host || reveal.section;
  return {
    id: slugify(`split-reveal-${index}-${root}`),
    type: 'scroll-reveal',
    label: `${selectorLabel(root)} split reveal`,
    root,
    action: `scrollintoview ${root}`,
    group: 'main-page-after-intro',
    waitMs: 1800,
    reason: 'Split reveal host detected on a ScrollTrigger page; use timed scroll capture: settle, arm, scroll into view, wait, dump.',
  };
}

function scrollTriggerCapture(st) {
  if (/partners|marquee|logo/i.test(st.trigger || '')) {
    return {
      id: slugify(`loop-${st.i}-${st.trigger}`),
      type: 'manual',
      label: `${selectorLabel(st.trigger)} in-view loop`,
      root: st.trigger,
      group: 'main-page-after-intro',
      waitMs: 1600,
      reason: `ScrollTrigger ${st.i} gates an in-view loop/marquee. Scroll into view first, then capture with a manual scan.`,
    };
  }
  return {
    id: slugify(`scroll-${st.i}-${st.trigger}`),
    type: 'scroll-reveal',
    label: `${selectorLabel(st.trigger)} scroll callback reveal`,
    root: st.trigger,
    action: `scrollintoview ${st.trigger}`,
    group: 'main-page-after-intro',
    waitMs: 1600,
    reason: `ScrollTrigger ${st.i} has callbacks (${st.callbacks.join(', ')}) but no bound tween in the registry.`,
  };
}

function planFromMap(runDir, flags = {}) {
  const manifest = optionalJson(path.join(runDir, 'manifest.json'), {});
  const map = optionalJson(path.join(runDir, 'map.json'), null);
  if (!map) throw new Error(`Map not found: ${path.join(runDir, 'map.json')}`);
  if (!manifest.url) throw new Error(`Manifest with url not found: ${path.join(runDir, 'manifest.json')}`);

  const state = {
    captures: [],
    ids: new Set(),
    signatures: new Set(),
    skipped: [],
  };
  for (const capture of manifest.captures || []) {
    addPlannedCapture(state, capture);
  }

  // A cross-origin dominant iframe means every selector below resolves into the
  // embed/shell chrome, never the real content. Don't silently proceed: record
  // the finding so the plan, report, and metrics all carry the real URL. The
  // shell captures are still emitted (and will be honestly attributed to
  // wrong_document_iframe at capture time) rather than masquerading as misses.
  const crossOriginIframe = (map.dominantIframe && map.dominantIframe.present !== false && map.dominantIframe.src
    && !(map.dominantIframe.sameOrigin && map.dominantIframe.accessible))
    ? { src: map.dominantIframe.src, areaRatio: map.dominantIframe.areaRatio }
    : null;
  if (crossOriginIframe) {
    state.skipped.push({
      id: 'cross-origin-iframe',
      reason: `Primary content is a cross-origin iframe (${pctText(crossOriginIframe.areaRatio)} of viewport): ${crossOriginIframe.src}. Promoted captures below target the embed shell only; re-run motion-decompile against that URL for the real animations.`,
    });
  }

  const splitReveals = Array.isArray(map.splitReveals) ? map.splitReveals.filter(reveal => reveal.host) : [];
  const splitSelectors = splitBootSelectors(map);
  if (splitReveals.length && stackHasScrollTrigger(map)) {
    splitReveals.slice(0, 12).forEach((reveal, index) => {
      addPlannedCapture(state, splitRevealScrollCapture(reveal, index));
    });
  } else if (splitSelectors.length) {
    addPlannedCapture(state, {
      id: 'boot-load-reveals',
      type: 'boot',
      label: 'Boot/load split reveal capture',
      fresh: true,
      seedReuse: true,
      seedGroup: 'main-page-after-intro',
      boot: { selectors: splitSelectors, ms: 4000 },
      waitMs: 4300,
      reason: `Map found ${(map.splitReveals || []).length} split reveal host(s); load captures require __capAutoBoot before page JS runs.`,
    });
  }

  for (const st of Array.isArray(map.scrollTriggers) ? map.scrollTriggers : []) {
    const hasCallbacks = st.callbacks && st.callbacks.length;
    const hasBoundTween = st.anims && st.anims.length;
    if (!hasCallbacks || hasBoundTween) continue;
    if (!st.trigger) {
      state.skipped.push({
        id: `scrolltrigger-${st.i}`,
        reason: 'Callback-only ScrollTrigger has no trigger selector in map.json.',
      });
      continue;
    }
    addPlannedCapture(state, scrollTriggerCapture(st));
  }

  const accordionRoot = inferAccordionRoot(map);
  if (accordionRoot) {
    const action = inferAccordionAction(map, accordionRoot);
    addPlannedCapture(state, {
      id: 'accordion-click',
      type: 'click',
      label: 'Accordion open/close',
      root: accordionRoot,
      action,
      scrollTarget: selectorFromAction(action) || accordionRoot,
      fresh: true,
      waitMs: 900,
      reason: 'Accordion or FAQ selectors were present in the map. Stateful click is isolated by default; add resetAction + reusePage:true if batching is safe.',
    });
  }

  const groupedCssHovers = new Map();
  for (const hover of map.cssHovers || []) {
    if (!hover.sel || /accordion|faq/i.test(hover.sel)) continue;
    if (genericSelector(hover.sel)) {
      state.skipped.push({ id: slugify(`css-hover-${hover.sel}`), reason: 'Generic tag selector is too broad for a default live capture.' });
      continue;
    }
    const coveredReason = cssHoverCoveredByParent(hover, map);
    if (coveredReason) {
      state.skipped.push({ id: slugify(`css-hover-${hover.sel}`), reason: `${coveredReason}.` });
      continue;
    }
    const key = `${hover.prop}|${hover.dur}|${hover.ease}`;
    if (!groupedCssHovers.has(key)) groupedCssHovers.set(key, hover);
  }
  for (const hover of groupedCssHovers.values()) {
    addPlannedCapture(state, {
      id: slugify(`css-hover-${hover.sel}`),
      type: 'hover',
      label: `${selectorLabel(hover.sel)} CSS hover`,
      root: hover.sel,
      action: `hover ${hover.sel}`,
      group: 'main-page-after-intro',
      waitMs: Math.min(2200, Math.max(900, Math.round(maxTransitionMs(hover.dur) + 650))),
      reason: `Representative CSS hover group: ${hover.prop} ${hover.dur} ${hover.ease}.`,
    });
  }

  const maxHoverCaptures = Number.isFinite(flags.maxHoverCaptures) ? flags.maxHoverCaptures : 10;
  const coveredSelectors = new Set(state.captures.map(capture => capture.root).filter(Boolean));
  const hoverGroups = new Map();
  for (const selector of map.hoverCandidates || []) {
    if (!selector || coveredSelectors.has(selector)) continue;
    if (/accordion|faq/i.test(selector)) continue;
    if (genericSelector(selector)) {
      state.skipped.push({ id: slugify(`hover-${selector}`), reason: 'Generic tag selector is too broad for a default live capture.' });
      continue;
    }
    if (/u-sprite|sprite/i.test(selector)) {
      state.skipped.push({ id: slugify(`hover-${selector}`), reason: 'Sprite/keyframe elements are represented by loop entries, not hover captures.' });
      continue;
    }
    if (generatedSelector(selector)) {
      state.skipped.push({ id: slugify(`hover-${selector}`), reason: 'Generated Webflow node id is too brittle for a default capture plan.' });
      continue;
    }
    const group = hoverPlanGroup(selector);
    const current = hoverGroups.get(group.id);
    const score = hoverSelectorScore(selector);
    if (!current || score < current.score) {
      hoverGroups.set(group.id, { selector, priority: group.priority, score });
    }
  }
  const hoverItems = [...hoverGroups.entries()]
    .sort((a, b) => a[1].priority - b[1].priority)
    .slice(0, maxHoverCaptures);
  for (const [groupId, item] of hoverItems) {
    addPlannedCapture(state, {
      id: groupId,
      type: 'hover',
      label: `${selectorLabel(item.selector)} hover`,
      root: item.selector,
      action: `hover ${item.selector}`,
      group: 'main-page-after-intro',
      waitMs: 1300,
      reason: `Representative hover candidate for ${groupId}; deduped from ${map.hoverCandidates.length} mapped hover candidate(s).`,
    });
  }

  const proposed = plainStrings({
    url: manifest.url,
    viewport: normalizeViewport(manifest),
    crossOriginIframe,
    captureStrategy: manifest.captureStrategy || 'reuse-page',
    captureGroups: Object.assign({
      'main-page-after-intro': {
        resetScroll: true,
        reason: 'Reusable settled page for non-stateful hover, scroll, and manual captures.',
      },
    }, manifest.captureGroups || {}),
    initialWaitMs: manifest.initialWaitMs || 1500,
    captureInitialWaitMs: manifest.captureInitialWaitMs || 1500,
    generatedBy: 'bin/motion-decompile plan',
    generatedAt: new Date().toISOString(),
    captures: state.captures,
  });
  const outName = flags.out || 'manifest.proposed.json';
  const outFile = path.isAbsolute(outName) ? outName : path.join(runDir, outName);
  writeJson(outFile, proposed);
  const plan = plainStrings({
    generatedAt: proposed.generatedAt,
    sourceMap: 'map.json',
    manifest: path.relative(runDir, outFile),
    counts: {
      proposedCaptures: state.captures.length,
      scrollTriggers: Array.isArray(map.scrollTriggers) ? map.scrollTriggers.length : 0,
      hoverCandidates: (map.hoverCandidates || []).length,
      cssHovers: (map.cssHovers || []).length,
      splitReveals: (map.splitReveals || []).length,
      skipped: state.skipped.length,
    },
    skipped: state.skipped,
  });
  writeJson(path.join(runDir, 'capture-plan.json'), plan);
  fs.writeFileSync(path.join(runDir, 'capture-plan.md'), renderCapturePlanMarkdown(proposed, plan));
  appendLog(runDir, `\nSaved capture plan: \`${path.relative(runDir, outFile)}\`, \`capture-plan.md\`\n`);
  return { manifest: proposed, manifestFile: outFile, plan };
}

function renderCapturePlanMarkdown(manifest, plan) {
  const lines = [];
  lines.push('# Capture Plan');
  lines.push('');
  lines.push(`Generated: ${reportText(plan.generatedAt)}`);
  lines.push(`URL: ${reportText(manifest.url)}`);
  lines.push(`Viewport: ${manifest.viewport.join('x')}`);
  lines.push(`Manifest: ${reportText(plan.manifest)}`);
  lines.push(`Capture strategy: ${reportText(manifest.captureStrategy || 'fresh')}`);
  lines.push('');
  lines.push('## Summary');
  lines.push('');
  lines.push(`- Proposed captures: ${plan.counts.proposedCaptures}`);
  lines.push(`- ScrollTriggers in map: ${plan.counts.scrollTriggers}`);
  lines.push(`- Hover candidates in map: ${plan.counts.hoverCandidates}`);
  lines.push(`- CSS hover timing groups: ${plan.counts.cssHovers}`);
  lines.push(`- Split reveal hosts: ${plan.counts.splitReveals}`);
  lines.push('');
  lines.push('## Proposed Captures');
  lines.push('');
  lines.push(tableRow(['ID', 'Type', 'Page', 'Root', 'Wait', 'Reason']));
  lines.push(tableRow(['--', '--', '--', '--', '--', '--']));
  for (const capture of manifest.captures || []) {
    lines.push(tableRow([
      capture.id,
      capture.type,
      capture.fresh ? 'fresh' : (capture.group || ''),
      capture.root || (capture.boot ? `boot:${(capture.boot.selectors || []).length} selectors` : ''),
      capture.waitMs || '',
      capture.reason || '',
    ]));
  }
  lines.push('');
  if (plan.skipped.length) {
    lines.push('## Skipped');
    lines.push('');
    for (const item of plan.skipped) lines.push(`- **${reportText(item.id)}**: ${reportText(item.reason)}`);
    lines.push('');
  }
  lines.push('## Next');
  lines.push('');
  lines.push(`Run \`./bin/motion-decompile capture <run-dir> ${reportText(plan.manifest)}\` after reviewing selectors.`);
  lines.push('');
  return lines.join('\n');
}

function timelineAnimation(runDir, result, capture) {
  const ref = relativeTimelineRef(runDir, result);
  if (!ref) return null;
  const file = path.join(runDir, ref);
  if (!fs.existsSync(file)) return null;
  const timeline = readJson(file);
  const id = slugify(result.id || timeline.meta?.captureSource || path.basename(ref, '.json'));
  const trigger = capture?.type || result.type || timeline.meta?.trigger || 'manual';
  const leadFinding = chooseLeadFinding(timeline, trigger);
  if (!leadFinding) {
    return {
      id,
      label: capture?.label || labelFromId(id),
      selector: capture?.root || capture?.selector || timeline.meta?.rootSelector || '',
      trigger: trigger === 'manual' && capture?.type ? capture.type : trigger,
      mechanism: 'no measured motion',
      patternId: capture?.patternId || null,
      layers: 0,
      stagger: null,
      lead: {
        selector: capture?.root || capture?.selector || timeline.meta?.rootSelector || '',
        from: {},
        to: {},
        duration: 'none measured',
        ease: 'none measured',
        easeBezier: null,
      },
      confidence: 'unknown - verify',
      timelineRef: ref,
      empty: true,
      notes: capture?.notes || result.summary || timeline.summary || 'No animation was captured. Check selector visibility and trigger recipe.',
    };
  }
  const prop = findingProperty(leadFinding);
  const timing = findingTiming(leadFinding, prop.value);
  const selector = capture?.root || capture?.selector || timeline.meta?.rootSelector || leadFinding?.selector || '';
  const leadSelector = leadFinding?.locator?.uniqueSelector || leadFinding?.locator?.shortSelector || leadFinding?.selector || selector;
  const from = stateForProperty(prop.name, prop.value?.from ?? leadFinding?.from);
  const to = stateForProperty(prop.name, prop.value?.to ?? leadFinding?.to);
  const mechanism = capture?.mechanism || [...new Set((timeline.findings || []).map(finding => finding.type || finding.leadProperty).filter(Boolean))].join(' + ') || 'motion';
  const confidence = capture?.confidence || confidenceFor(leadFinding, timing, timeline);
  const duration = capture?.duration || timing.duration || (timeline.meta?.durationMs ? `${Math.round(timeline.meta.durationMs)}ms measured` : 'unknown');
  const ease = capture?.ease || timing.easing || 'unknown';
  const reflowNoise = revealLikeTrigger(trigger) ? boxOnlyTextReflowFindings(timeline.findings || []) : [];
  let notes = capture?.notes || timeline.summary || '';
  if (reflowNoise.length) {
    const message = preferredRevealFinding(timeline.findings || [])
      ? `Ignored ${reflowNoise.length} text-fragment width/height reflow finding(s) while choosing the transform/opacity reveal lead.`
      : `Only text-fragment width/height reflow was captured; verify this as layout noise before treating it as authored motion.`;
    notes = notes ? `${notes} ${message}` : message;
  }
  return {
    id,
    label: capture?.label || labelFromId(id),
    selector,
    trigger: trigger === 'manual' && capture?.type ? capture.type : trigger,
    mechanism,
    patternId: capture?.patternId || null,
    layers: timeline.findings?.length || timeline.meta?.elementsMoved || 0,
    stagger: capture?.stagger || summarizeStagger(timeline.stagger),
    lead: {
      selector: leadSelector,
      from,
      to,
      duration,
      ease,
      easeBezier: cubicBezier(ease),
    },
    confidence,
    timelineRef: ref,
    notes,
  };
}

function scrollTriggerAnimations(map, patterns) {
  const animations = [];
  const triggers = Array.isArray(map?.scrollTriggers) ? map.scrollTriggers : [];
  if (triggers.some(st => st.scrub && st.anims && st.anims.length)) {
    uniquePush(patterns, {
      id: 'p-scroll-scrub',
      trigger: 'scroll',
      appliesTo: `${triggers.filter(st => st.scrub && st.anims && st.anims.length).length} ScrollTrigger scrub tween(s)`,
      summary: 'Registry-backed ScrollTrigger tween with scrubbed progress.',
      confidence: 'measured',
    });
  }
  if (triggers.some(st => st.callbacks && st.callbacks.length && (!st.anims || !st.anims.length))) {
    uniquePush(patterns, {
      id: 'p-scroll-callback',
      trigger: 'scroll',
      appliesTo: `${triggers.filter(st => st.callbacks && st.callbacks.length && (!st.anims || !st.anims.length)).length} callback-only ScrollTrigger(s)`,
      summary: 'Callback-controlled motion. Needs timeline capture to recover from/to values.',
      confidence: 'unknown - verify',
    });
  }

  for (const st of triggers) {
    const anims = Array.isArray(st.anims) ? st.anims : [];
    if (anims.length) {
      // Group near-identical tweens within one ScrollTrigger (same target,
      // mechanism, duration, ease) into a single entry. A drawSVG ScrollTrigger
      // can bind 20+ identical "path" tweens; emitting one row per path floods
      // the spec with duplicates that all say the same thing.
      const groups = new Map();
      anims.forEach((anim, animIndex) => {
        const target = anim.targets?.[0] || st.trigger;
        const props = Object.fromEntries(Object.entries(anim.props || {}).filter(([key]) => key !== 'lazy'));
        const mechanism = mechanismFromProps(props);
        const key = JSON.stringify([target || st.trigger, mechanism, anim.duration ?? null, anim.ease || 'unknown']);
        let group = groups.get(key);
        if (!group) {
          group = { animIndex, target, props, mechanism, anim, count: 0, layers: 0 };
          groups.set(key, group);
        }
        group.count += 1;
        group.layers += anim.targetCount || anim.targets?.length || 1;
      });
      for (const { animIndex, target, props, mechanism, anim, count, layers } of groups.values()) {
        const grouped = count > 1;
        const base = `start: ${st.start || 'unknown'}; end: ${st.end || 'unknown'}; scrub: ${Boolean(st.scrub)}.`;
        animations.push({
          id: slugify(`scrolltrigger-${st.i}-${animIndex}-${target || st.trigger}`),
          label: `${selectorLabel(target || st.trigger)} scroll motion${grouped ? ` (×${count})` : ''}`,
          selector: target || st.trigger,
          trigger: 'scroll',
          mechanism,
          patternId: st.scrub ? 'p-scroll-scrub' : null,
          count,
          layers,
          stagger: anim.stagger ? { items: anim.targetCount || null, ms: anim.stagger } : null,
          lead: {
            selector: target || st.trigger,
            from: {},
            to: props,
            duration: st.scrub ? `scroll scrub, registry tween duration ${seconds(anim.duration)}` : seconds(anim.duration),
            ease: anim.ease || 'unknown',
            easeBezier: cubicBezier(anim.ease),
          },
          confidence: 'measured',
          timelineRef: `map.json#scrollTriggers[${st.i}]`,
          notes: grouped
            ? `${count} near-identical registry tweens grouped (${layers} targets total). ${base}`
            : base,
        });
      }
    } else if (st.callbacks && st.callbacks.length) {
      animations.push({
        id: slugify(`scrolltrigger-${st.i}-${st.trigger || 'callback'}`),
        label: `${selectorLabel(st.trigger)} callback scroll motion`,
        selector: st.trigger,
        trigger: 'scroll',
        mechanism: 'callback-controlled motion',
        patternId: 'p-scroll-callback',
        layers: 0,
        stagger: null,
        lead: {
          selector: st.trigger,
          from: {},
          to: {},
          duration: 'unknown',
          ease: 'unknown',
          easeBezier: null,
        },
        confidence: 'unknown - verify',
        timelineRef: `map.json#scrollTriggers[${st.i}]`,
        notes: `Callbacks: ${st.callbacks.join(', ')}. No bound registry tween was available; capture this item for measured values.`,
      });
    }
  }
  return animations;
}

function loopAnimations(map, patterns) {
  const loops = [];
  const seen = new Set();
  for (const loop of Array.isArray(map?.loops) ? map.loops : []) {
    const key = `${loop.sel}|${loop.name}|${loop.dur}|${loop.timing}`;
    if (seen.has(key)) continue;
    seen.add(key);
    loops.push(loop);
  }
  const groups = new Map();
  for (const loop of loops) {
    const key = `${loop.name}|${loop.dur}|${loop.timing}`;
    groups.set(key, (groups.get(key) || 0) + 1);
  }
  for (const [key, count] of groups) {
    const [name, dur, timing] = key.split('|');
    uniquePush(patterns, {
      id: slugify(`p-css-loop-${name}-${dur}-${timing}`),
      trigger: 'load',
      appliesTo: `${count} element(s)`,
      summary: `${dur} infinite CSS keyframes ${name} with ${timing}.`,
      confidence: 'measured',
    });
  }
  return loops.map((loop, index) => ({
    id: slugify(`css-loop-${index}-${loop.name}-${loop.sel}`),
    label: `${selectorLabel(loop.sel)} CSS loop`,
    selector: loop.sel,
    trigger: 'load',
    mechanism: 'CSS keyframes',
    patternId: slugify(`p-css-loop-${loop.name}-${loop.dur}-${loop.timing}`),
    layers: 1,
    stagger: null,
    lead: {
      selector: loop.sel,
      from: { state: `CSS keyframes ${loop.name}` },
      to: { state: `CSS keyframes ${loop.name}` },
      duration: `${loop.dur} infinite`,
      ease: loop.timing || 'unknown',
      easeBezier: cubicBezier(loop.timing),
    },
    confidence: 'measured',
    timelineRef: null,
    notes: `Read from map loop entry ${index}.`,
  }));
}

function cssHoverAnimations(map, patterns) {
  const hovers = Array.isArray(map?.cssHovers) ? map.cssHovers : [];
  const groups = new Map();
  for (const hover of hovers) {
    const key = `${hover.prop}|${hover.dur}|${hover.ease}`;
    groups.set(key, (groups.get(key) || 0) + 1);
  }
  for (const [key, count] of groups) {
    const [prop, dur, ease] = key.split('|');
    uniquePush(patterns, {
      id: slugify(`p-css-hover-${prop}-${dur}-${ease}`),
      trigger: 'hover',
      appliesTo: `${count} CSS hover transition(s)`,
      summary: `${prop} transition over ${dur} with ${ease}.`,
      confidence: 'unknown - verify',
    });
  }
  return hovers.map((hover, index) => ({
    id: slugify(`css-hover-${index}-${hover.sel}`),
    label: `${selectorLabel(hover.sel)} hover transition`,
    selector: hover.sel,
    trigger: 'hover',
    mechanism: hover.prop || 'CSS transition',
    patternId: slugify(`p-css-hover-${hover.prop}-${hover.dur}-${hover.ease}`),
    layers: 1,
    stagger: null,
    lead: {
      selector: hover.sel,
      from: { state: 'not captured' },
      to: { state: 'not captured' },
      duration: hover.dur || 'unknown',
      ease: hover.ease || 'unknown',
      easeBezier: cubicBezier(hover.ease),
    },
    confidence: 'unknown - verify',
    timelineRef: null,
    notes: 'Timing came from static CSS transition data. Run a live capture for measured from/to deltas.',
  }));
}

function splitRevealAnimations(map, patterns) {
  const reveals = Array.isArray(map?.splitReveals) ? map.splitReveals : [];
  const trigger = stackHasScrollTrigger(map) ? 'scroll' : 'load';
  if (reveals.length) {
    uniquePush(patterns, {
      id: 'p-split-reveal',
      trigger,
      appliesTo: `${reveals.length} mapped split reveal host(s)`,
      summary: stackHasScrollTrigger(map)
        ? 'SplitText or line-mask reveal host detected on a ScrollTrigger page; capture by scrolling the host into view.'
        : 'SplitText or line-mask reveal host detected structurally.',
      confidence: 'unknown - verify',
    });
  }
  return reveals.map((reveal, index) => ({
    id: slugify(`split-reveal-${index}-${reveal.host}`),
    label: `${selectorLabel(reveal.host)} split reveal`,
    selector: reveal.host,
    trigger,
    mechanism: 'splittext line-mask reveal',
    patternId: 'p-split-reveal',
    layers: reveal.count || 0,
    stagger: null,
    lead: {
      selector: reveal.host,
      from: { state: 'split nodes present before reveal' },
      to: { state: 'visible split content' },
      duration: 'unknown',
      ease: 'unknown',
      easeBezier: null,
    },
    confidence: 'unknown - verify',
    timelineRef: null,
    notes: `Kinds: ${(reveal.kinds || []).join(', ') || 'unknown'}. Section: ${reveal.section || 'unknown'}.`,
  }));
}

function applyTokens(spec) {
  const tokens = Object.assign({}, spec.tokens || {});
  const easeCounts = new Map();
  const durationCounts = new Map();
  for (const animation of spec.animations) {
    const ease = animation.lead?.easeBezier;
    if (ease) easeCounts.set(ease, (easeCounts.get(ease) || 0) + 1);
    const duration = animation.lead?.duration;
    if (duration && !/unknown|scroll scrub|infinite/i.test(duration)) {
      durationCounts.set(duration, (durationCounts.get(duration) || 0) + 1);
    }
  }
  for (const [ease, count] of easeCounts) {
    if (count < 2) continue;
    const id = `ease.${slugPart(ease).replace(/^cubic-bezier-/, 'cubic-')}`;
    tokens[id] = { bezier: ease };
    for (const animation of spec.animations) {
      if (animation.lead?.easeBezier === ease) animation.lead.ease = id;
    }
  }
  for (const [duration, count] of durationCounts) {
    if (count < 2) continue;
    const id = `dur.${slugPart(duration)}`;
    tokens[id] = duration;
  }
  spec.tokens = tokens;
  return spec;
}

function assembleSpec(runDir) {
  const manifest = optionalJson(path.join(runDir, 'manifest.json'), {});
  const map = optionalJson(path.join(runDir, 'map.json'), {});
  const patterns = [];
  const animations = [];

  for (const pattern of manifest.patterns || []) uniquePush(patterns, pattern);
  animations.push(...scrollTriggerAnimations(map, patterns));
  animations.push(...loopAnimations(map, patterns));
  animations.push(...cssHoverAnimations(map, patterns));
  animations.push(...splitRevealAnimations(map, patterns));

  const captures = mapCaptureById(manifest);
  for (const result of timelineResults(runDir)) {
    const capture = captures.get(result.id) || {};
    const animation = timelineAnimation(runDir, result, capture);
    if (animation) animations.push(animation);
  }
  for (const animation of manifest.animations || []) animations.push(animation);

  const stack = map.libs || [];
  const spec = applyTokens({
    meta: {
      url: manifest.url || map.url || null,
      capturedAt: today(),
      viewport: normalizeViewport(manifest),
      stack,
      method: manifest.method || 'Generated by bin/motion-decompile from map.json and timelines/*.json.',
      notes: manifest.notes || 'Autogenerated first-pass spec. Entries marked unknown - verify need a targeted capture or human review before recreation.',
    },
    tokens: manifest.tokens || {},
    patterns,
    animations,
    unspecced: manifest.unspecced || [],
  });
  tagVendorAnimations(spec);

  if (map.hoverCandidates && map.hoverCandidates.length) {
    const captured = new Set((manifest.captures || []).map((capture, index) => captureId(capture, index)));
    spec.unspecced.push({
      id: 'remaining-hover-candidates',
      note: `Static map found ${map.hoverCandidates.length} hover candidate(s). Captured ${captured.size}; dedupe and capture representative remaining mechanisms as needed.`,
    });
  }

  const plainSpec = plainStrings(spec);
  writeJson(path.join(runDir, 'animations.json'), plainSpec);
  fs.writeFileSync(path.join(runDir, 'animations.md'), renderAnimationsMarkdown(plainSpec));
  appendLog(runDir, `\nSaved assembler output: \`animations.json\`, \`animations.md\`\n`);
  return plainSpec;
}

function animationLine(animation) {
  const lead = animation.lead || {};
  const bits = [
    `**${reportText(animation.label || animation.id)}** (${animation.id})`,
    animation.trigger,
    animation.mechanism,
    `layers: ${animation.layers ?? 0}`,
    `duration: ${lead.duration || 'unknown'}`,
    `ease: ${lead.ease || lead.easeBezier || 'unknown'}`,
    `confidence: ${animation.confidence || 'unknown - verify'}`,
  ];
  if (animation.timelineRef) bits.push(`ref: ${animation.timelineRef}`);
  return `- ${bits.map(reportText).join(' · ')}`;
}

function confidenceCounts(animations) {
  const counts = new Map();
  for (const animation of animations) {
    const key = animation.confidence || 'unknown - verify';
    counts.set(key, (counts.get(key) || 0) + 1);
  }
  return [...counts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
}

// Known third-party widgets / payment buttons / consent banners that inject
// their own @keyframes or transitions into host pages. Their motion is real but
// it isn't the *site's* signature, so matches are de-ranked out of the signature
// tier (kept in the spec, labeled with the matched source). Maintainable: add a
// { source, re } row to extend coverage. Matched against an animation's id,
// label, selector, and keyframe-name states.
const VENDOR_ANIMATION_DENYLIST = [
  { source: 'Shopify Shop Pay / accelerated checkout', re: /acceleratedcheckout|shop-?pay|shopify-payment-button|wallet-cart-button|dynamic-checkout/i },
  { source: 'Intercom', re: /\bintercom\b/i },
  { source: 'Drift', re: /\bdrift-(?:widget|frame|controller)/i },
  { source: 'Zendesk / Zopim', re: /zendesk|zopim|\bzewidget/i },
  { source: 'Tawk.to', re: /\btawk[-_]?(?:to|chat|widget)?/i },
  { source: 'Crisp', re: /crisp-client/i },
  { source: 'HubSpot', re: /hubspot|hs-(?:web-interactives|messages|forms|shadow)/i },
  { source: 'OneTrust consent', re: /onetrust|optanon/i },
  { source: 'Cookiebot consent', re: /cookiebot|cookieconsent/i },
  { source: 'Osano consent', re: /\bosano\b/i },
  { source: 'CookieYes consent', re: /cookieyes|\bcky-/i },
  { source: 'Google reCAPTCHA', re: /grecaptcha|recaptcha/i },
  { source: 'Stripe', re: /__privatestripe|stripe-button/i },
  { source: 'Klaviyo', re: /klaviyo|kl-private/i },
  { source: 'Calendly', re: /calendly/i },
];

function vendorAnimationMatch(animation) {
  const haystack = [
    animation.id,
    animation.label,
    animation.selector,
    animation.lead?.selector,
    animation.lead?.from?.state,
    animation.lead?.to?.state,
  ].filter(Boolean).join(' ');
  for (const entry of VENDOR_ANIMATION_DENYLIST) {
    if (entry.re.test(haystack)) return entry.source;
  }
  return null;
}

// Flag vendor/injected animations so the renderer can keep them in the spec but
// out of the signature tier, with the matched source recorded for humans.
function tagVendorAnimations(spec) {
  for (const animation of spec.animations || []) {
    const source = vendorAnimationMatch(animation);
    if (!source) continue;
    animation.vendor = source;
    const note = `Third-party/injected animation (${source}); de-ranked from the signature tier.`;
    animation.notes = animation.notes ? `${animation.notes} ${note}` : note;
  }
  return spec;
}

function signatureScore(animation) {
  let score = 0;
  if (animation.timelineRef && /^timelines\//.test(animation.timelineRef)) score += 100;
  if (['hover', 'click'].includes(animation.trigger)) score += 35;
  if (['load', 'scroll'].includes(animation.trigger)) score += 20;
  if (animation.confidence === 'measured') score += 15;
  if (animation.empty) score -= 80;
  score += Math.min(60, Number(animation.layers || 0) * 6);
  return score;
}

function renderAnimationsMarkdown(spec) {
  const lines = [];
  const animations = spec.animations || [];
  const nonVendor = animations.filter(animation => !animation.vendor);
  const vendor = animations.filter(animation => animation.vendor);
  const signature = nonVendor
    .filter(animation => !animation.empty && (animation.timelineRef || ['load', 'scroll'].includes(animation.trigger) || Number(animation.layers || 0) >= 5))
    .sort((a, b) => signatureScore(b) - signatureScore(a))
    .slice(0, 12);
  const signatureItems = signature.length ? signature : nonVendor.slice(0, 8);
  const signatureSet = new Set(signatureItems.map(animation => animation.id));
  const polish = animations.filter(animation => !signatureSet.has(animation.id) && animation.confidence === 'measured' && !animation.vendor);
  const needsVerify = animations.filter(animation => animation.confidence !== 'measured');

  lines.push('# Animation Spec');
  lines.push('');
  lines.push(`Source: ${spec.meta?.url || 'unknown'}`);
  lines.push(`Captured: ${spec.meta?.capturedAt || 'unknown'}`);
  if (spec.meta?.viewport) lines.push(`Viewport: ${spec.meta.viewport.join('x')}`);
  lines.push(`Stack: ${(spec.meta?.stack || []).join(', ') || '(none detected)'}`);
  lines.push('');
  lines.push('## Signature moments');
  if (signatureItems.length) signatureItems.forEach(animation => lines.push(animationLine(animation)));
  else lines.push('- None identified.');
  lines.push('');
  lines.push('## Patterns');
  if (spec.patterns?.length) {
    for (const pattern of spec.patterns) {
      lines.push(`- **${reportText(pattern.id)}** · ${reportText(pattern.trigger)} · ${reportText(pattern.appliesTo)} · ${reportText(pattern.summary)} · confidence: ${reportText(pattern.confidence)}`);
    }
  } else {
    lines.push('- None identified.');
  }
  lines.push('');
  lines.push('## Polish');
  if (polish.length) polish.forEach(animation => lines.push(animationLine(animation)));
  else lines.push('- None identified.');
  lines.push('');
  lines.push('## Third-party / vendor (de-ranked)');
  if (vendor.length) {
    for (const animation of vendor) {
      lines.push(`- **${reportText(animation.label || animation.id)}** (${reportText(animation.id)}) · source: ${reportText(animation.vendor)} · ${reportText(animation.mechanism)} · kept in spec, excluded from signature.`);
    }
  } else {
    lines.push('- None detected.');
  }
  lines.push('');
  lines.push('## Needs verify');
  if (needsVerify.length) {
    for (const animation of needsVerify) {
      lines.push(`- **${reportText(animation.id)}** · ${reportText(animation.notes || 'Review before recreation.')}`);
    }
  } else {
    lines.push('- None.');
  }
  lines.push('');
  lines.push("## Can't spec-capture");
  if (spec.unspecced?.length) {
    for (const item of spec.unspecced) lines.push(`- **${reportText(item.id)}** · ${reportText(item.note)}`);
  } else {
    lines.push('- None logged.');
  }
  lines.push('');
  lines.push('## Confidence counts');
  for (const [confidence, count] of confidenceCounts(animations)) {
    lines.push(`- ${reportText(confidence)}: ${count}`);
  }
  lines.push('');
  return `${lines.join('\n')}`;
}

function captureResultsForReport(runDir) {
  const primary = optionalJson(path.join(runDir, 'capture-results.json'), { results: [] });
  const full = optionalJson(path.join(runDir, 'capture-results.full.json'), null);
  const merged = [];
  const seen = new Set();
  for (const source of [full, primary]) {
    for (const result of source?.results || []) {
      if (!result?.id || seen.has(result.id)) continue;
      seen.add(result.id);
      merged.push(result);
    }
  }
  return {
    results: merged,
    hasFull: Boolean(full?.results?.length),
    primaryCount: primary.results?.length || 0,
    fullCount: full?.results?.length || 0,
  };
}

function captureStatus(result, timeline) {
  if (result.status === 'error') return 'error';
  if (result.status === 'skipped') return 'skipped';
  if (result.status && result.status !== 'ok') return result.status;
  const moved = timeline.meta?.elementsMoved ?? result.findings ?? 0;
  if (!Number(moved)) return 'empty';
  const stop = timeline.meta?.terminationReason || '';
  if (/maxDuration|manualDump/.test(stop)) return 'check';
  return 'ok';
}

function pageStrategyLabel(page) {
  if (!page) return '';
  const bits = [page.strategy || 'fresh'];
  if (page.group) bits.push(page.group);
  if (page.opened === true) bits.push('opened');
  if (page.opened === false) bits.push('reused');
  if (page.seededBy) bits.push(`seeded by ${page.seededBy}`);
  if (page.seededReusablePage && page.seedGroup) bits.push(`seeds ${page.seedGroup}`);
  return bits.join(' / ');
}

function buildReport(runDir) {
  const manifest = optionalJson(path.join(runDir, 'manifest.json'), {});
  const map = optionalJson(path.join(runDir, 'map.json'), null);
  const pageState = optionalJson(path.join(runDir, 'page-state.json'), { records: [] });
  const captureResults = captureResultsForReport(runDir);
  const assembled = optionalJson(path.join(runDir, 'animations.json'), null);
  const rows = captureResults.results.map(result => {
    const timeline = result.timelineRef ? optionalJson(path.join(runDir, result.timelineRef), {}) : {};
    const moved = timeline.meta?.elementsMoved ?? result.findings ?? '';
    return tableRow([
      result.id,
      result.type,
      pageStrategyLabel(result.page),
      captureStatus(result, timeline),
      moved,
      result.stop || timeline.meta?.terminationReason || '',
      result.error || result.summary || timeline.summary || '',
      result.timelineRef || '',
    ]);
  });
  const emptyRows = captureResults.results
    .filter(result => {
      const timeline = result.timelineRef ? optionalJson(path.join(runDir, result.timelineRef), {}) : {};
      return captureStatus(result, timeline) === 'empty';
    })
    .map(result => `- **${reportText(result.id)}**${result.cause ? ` [cause: ${reportText(result.cause)}]` : ''}: ${reportText(result.summary || 'No animation captured')}. Try a tighter selector, a visible starting state, or a manual/in-view recipe.`);
  const failedRows = captureResults.results
    .filter(result => result.status === 'error')
    .map(result => `- **${reportText(result.id)}**${result.cause ? ` [cause: ${reportText(result.cause)}]` : ''}: ${reportText(result.error || result.summary || 'Capture failed')}`);

  const lines = [];
  lines.push('# Motion Decompile Report');
  lines.push('');
  lines.push(`Generated: ${new Date().toISOString()}`);
  if (manifest.url) lines.push(`URL: ${manifest.url}`);
  if (manifest.viewport) lines.push(`Viewport: ${manifest.viewport.join('x')}`);
  lines.push(`Run directory: ${runDir}`);
  lines.push('');

  const dom = map && map.dominantIframe;
  const retargeted = map && map.retargetedFrom;
  const thin = map && map.thinDocument && map.thinDocument.thin;
  if ((dom && dom.present !== false && dom.src) || retargeted || thin) {
    lines.push('## Primary content');
    lines.push('');
    if (dom && dom.present !== false && dom.src && !(dom.sameOrigin && dom.accessible)) {
      lines.push(`> **Primary content is a cross-origin iframe: ${reportText(dom.src)}** (${pctText(dom.areaRatio)} of the viewport). The mapped document is only the embed/shell chrome, so every promoted capture targets the shell, not the real animations. Re-run \`motion-decompile\` against that URL to decompile the actual content.`);
      lines.push('');
    } else if (retargeted) {
      lines.push(`> A dominant same-origin iframe (${pctText(retargeted.areaRatio)} of the viewport) was detected; the run was re-targeted from ${reportText(retargeted.url)} to its content document at **${reportText(retargeted.src)}**.`);
      lines.push('');
    }
    if (thin) {
      lines.push(`- Suspiciously thin document: scrollHeight ${map.thinDocument.scrollHeight}px vs innerHeight ${map.thinDocument.innerHeight}px, ${map.thinDocument.realContentElements} real content element(s), ${map.thinDocument.bodyTextLength} chars of body text. The top document carries little of its own content.`);
      lines.push('');
    }
  }

  lines.push('## Artifacts');
  lines.push('');
  lines.push('- `manifest.json`');
  if (map) lines.push('- `map.json`');
  if (pageState.records?.length) lines.push('- `page-state.json`');
  if (captureResults.primaryCount) lines.push('- `capture-results.json`');
  if (captureResults.hasFull) lines.push('- `capture-results.full.json`');
  if (fs.existsSync(path.join(runDir, 'capture-plan.md'))) {
    lines.push('- `manifest.proposed.json`');
    lines.push('- `capture-plan.json`');
    lines.push('- `capture-plan.md`');
  }
  if (assembled) {
    lines.push('- `animations.json`');
    lines.push('- `animations.md`');
  }
  lines.push('- `timelines/*.json`');
  lines.push('- `run-log.md`');
  lines.push('');

  if (map) {
    lines.push('## Map Summary');
    lines.push('');
    lines.push(`- Libraries: ${(map.libs || []).join(', ') || '(none detected)'}`);
    lines.push(`- ScrollTriggers: ${Array.isArray(map.scrollTriggers) ? map.scrollTriggers.length : 0}`);
    lines.push(`- Hover candidates: ${(map.hoverCandidates || []).length}`);
    lines.push(`- CSS hovers: ${(map.cssHovers || []).length}`);
    lines.push(`- Loops: ${(map.loops || []).length}`);
    lines.push(`- Split reveals: ${(map.splitReveals || []).length}`);
    lines.push('');
  }

  const pageStateIssues = (pageState.records || [])
    .filter(record => record.outcome && record.outcome !== 'ready')
    .map(record => `- **${reportText(record.phase)}**: ${reportText(record.outcome)}${record.state?.blockers?.length ? ` - ${reportText(pageBlockerSummary(record.state))}` : ''}`);
  if (pageState.records?.length) {
    lines.push('## Page State');
    lines.push('');
    lines.push(`- Readiness samples: ${pageState.records.length}`);
    if (pageStateIssues.length) lines.push(...pageStateIssues);
    else lines.push('- No loader, challenge, or rate-limit blockers detected by the readiness probe.');
    lines.push('');
  }

  lines.push('## Captures');
  lines.push('');
  if (rows.length) {
    lines.push(tableRow(['ID', 'Type', 'Page', 'Status', 'Moved', 'Stop', 'Summary', 'Timeline']));
    lines.push(tableRow(['--', '--', '--', '--', '--', '--', '--', '--']));
    lines.push(...rows);
  } else {
    lines.push('No timelines have been saved yet.');
  }
  lines.push('');

  if (emptyRows.length) {
    lines.push('## Empty Captures');
    lines.push('');
    lines.push(...emptyRows);
    lines.push('');
  }

  if (failedRows.length) {
    lines.push('## Failed Captures');
    lines.push('');
    lines.push(...failedRows);
    lines.push('');
  }

  const skipped = (manifest.captures || []).filter(capture => capture.skip || capture.enabled === false);
  if (skipped.length) {
    lines.push('## Skipped');
    lines.push('');
    for (const capture of skipped) {
      lines.push(`- ${capture.id || '(unnamed)'}: ${capture.reason || 'marked skipped'}`);
    }
    lines.push('');
  }

  lines.push('## Notes');
  lines.push('');
  if (assembled) lines.push('- `animations.json` is the canonical assembled spec; `animations.md` is rendered from it.');
  else lines.push('- Run `bin/motion-decompile assemble <run-dir>` to create `animations.json` and `animations.md`.');
  lines.push('- Capture reliability still depends on selectors resolving in a real visible browser.');
  lines.push('');

  const report = lines.join('\n');
  fs.writeFileSync(path.join(runDir, 'report.md'), report);
  appendLog(runDir, `\nSaved report: \`report.md\`\n`);
  return report;
}

function initCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length !== 1) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const url = positionals[0];
  const viewport = flags.viewport || DEFAULT_VIEWPORT;
  const runDir = runDirFor(url, flags);
  ensureRunDir(runDir);
  const manifest = { url, viewport, captures: [] };
  writeJson(path.join(runDir, 'manifest.json'), manifest);
  appendLog(runDir, `Initialized run for ${url}`);
  if (!flags.noOpen) openPage(runDir, url, viewport, [ENGINE]);
  console.log(runDir);
}

function mapCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length !== 1) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const runDir = path.resolve(positionals[0]);
  ensureRunDir(runDir);
  const { manifest } = loadManifest(runDir);
  const map = runMap(runDir, manifest, flags);
  console.log(`Saved ${path.join(runDir, 'map.json')}`);
  console.log(`${(map.libs || []).join(', ') || 'No libraries detected'}; ${(map.hoverCandidates || []).length} hover candidates`);
}

function captureCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length < 1 || positionals.length > 2) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const runDir = path.resolve(positionals[0]);
  ensureRunDir(runDir);
  const { file, manifest } = loadManifest(runDir, positionals[1]);
  const results = runCapture(runDir, manifest, file, flags);
  console.log(`Saved ${timelineCount(results)} timeline(s) under ${path.join(runDir, 'timelines')}`);
  console.log(`Capture results: ${results.length}`);
}

function planCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length !== 1) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const runDir = path.resolve(positionals[0]);
  ensureRunDir(runDir);
  const result = planFromMap(runDir, flags);
  console.log(`Saved ${result.manifestFile}`);
  console.log(`Saved ${path.join(runDir, 'capture-plan.md')}`);
  console.log(`Proposed captures: ${result.manifest.captures.length}`);
}

function reportCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length !== 1) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const runDir = path.resolve(positionals[0]);
  ensureRunDir(runDir);
  buildReport(runDir);
  console.log(`Saved ${path.join(runDir, 'report.md')}`);
}

function assembleCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length !== 1) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const runDir = path.resolve(positionals[0]);
  ensureRunDir(runDir);
  const spec = assembleSpec(runDir);
  console.log(`Saved ${path.join(runDir, 'animations.json')}`);
  console.log(`Saved ${path.join(runDir, 'animations.md')}`);
  console.log(`Animations: ${spec.animations.length}; patterns: ${spec.patterns.length}; unspecced: ${spec.unspecced.length}`);
}

function runCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length !== 1) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const { file } = loadManifest(process.cwd(), positionals[0]);
  const { runDir, map, results, spec } = runFromManifestFile(file, flags);
  console.log(`Run: ${runDir}`);
  console.log(`Map: ${(map.libs || []).join(', ') || 'no libraries'}; ${(map.hoverCandidates || []).length} hover candidates`);
  console.log(`Timelines: ${timelineCount(results)}`);
  console.log(`Capture results: ${results.length}`);
  console.log(`Animations: ${spec.animations.length}`);
  console.log(`Spec: ${path.join(runDir, 'animations.json')}`);
  console.log(`Report: ${path.join(runDir, 'report.md')}`);
}

function scoutCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length !== 1) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  const { runDir, map, plan } = scoutUrl(positionals[0], flags);
  console.log(`Run: ${runDir}`);
  console.log(`Map: ${(map.libs || []).join(', ') || 'no libraries'}; ${(map.hoverCandidates || []).length} hover candidates`);
  console.log(`Proposed captures: ${plan.manifest.captures.length}`);
  console.log(`Plan: ${path.join(runDir, 'capture-plan.md')}`);
  console.log(`Next: ./bin/motion-decompile decompile ${quote(runDir)}`);
}

function isLikelyUrl(value) {
  return /^https?:\/\//i.test(String(value || ''));
}

function decompileCommand(argv) {
  const { flags, positionals } = parseFlags(argv);
  if (flags.help || positionals.length < 1 || positionals.length > 2) {
    usage();
    process.exit(flags.help ? 0 : 1);
  }
  let result;
  if (positionals.length === 1 && isLikelyUrl(positionals[0])) {
    result = decompileUrl(positionals[0], flags);
    console.log(`Run: ${result.runDir}`);
    console.log(`Proposed captures: ${result.plan.manifest.captures.length}`);
  } else if (positionals.length === 1 && fs.existsSync(path.resolve(positionals[0])) && fs.statSync(path.resolve(positionals[0])).isFile()) {
    result = runFromManifestFile(path.resolve(positionals[0]), flags);
    console.log(`Run: ${result.runDir}`);
  } else {
    const runDir = path.resolve(positionals[0]);
    result = decompileRunDir(runDir, positionals[1], flags);
    console.log(`Run: ${result.runDir}`);
    console.log(`Manifest: ${result.manifestFile}`);
  }
  console.log(`Timelines: ${timelineCount(result.results)}`);
  console.log(`Capture results: ${result.results.length}`);
  console.log(`Animations: ${result.spec.animations.length}`);
  console.log(`Spec: ${path.join(result.runDir, 'animations.json')}`);
  console.log(`Report: ${path.join(result.runDir, 'report.md')}`);
}

function main() {
  const [command, ...rest] = process.argv.slice(2);
  if (!command || command === '--help' || command === '-h') {
    usage();
    process.exit(command ? 0 : 1);
  }

  if (command === 'scout') scoutCommand(rest);
  else if (command === 'decompile') decompileCommand(rest);
  else if (command === 'init') initCommand(rest);
  else if (command === 'map') mapCommand(rest);
  else if (command === 'plan') planCommand(rest);
  else if (command === 'capture') captureCommand(rest);
  else if (command === 'assemble') assembleCommand(rest);
  else if (command === 'report') reportCommand(rest);
  else if (command === 'run') runCommand(rest);
  else throw new Error(`Unknown command: ${command}`);
}

if (require.main === module) {
  try {
    main();
  } catch (error) {
    console.error(`motion-decompile: ${error.message}`);
    process.exit(1);
  }
} else {
  // Requiring this file (e.g. from tests) exposes the spec-shaping internals
  // without running the CLI. Keep this surface small and intentional.
  module.exports = {
    actionLabel,
    scrollTriggerAnimations,
    vendorAnimationMatch,
    tagVendorAnimations,
    renderAnimationsMarkdown,
    // Capture-repair loop (Part 6) — exported for browser-free, model-free tests.
    runRepairLoop,
    validateRepairOutput,
    applyRepair,
    meetsSuccess,
    resultTriple,
    isStatefulRepairKind,
    repairConfig,
    invokeRepairProvider,
    buildRepairInput,
    REPAIR_ACTION_KINDS,
    TERMINAL_CAUSES,
    DEFAULT_REPAIRABLE_CAUSES,
    REPAIR_DEFAULTS,
  };
}
